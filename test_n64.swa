husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"

N64 add_one(N64 x) { rudisha x + 1; }

N32 main() {
    N64 val = 0;
    val = add_one(val);
    val = add_one(val);
    val = add_one(val);
    N32 v32 = val;
    andika("; val=%d (expect 3)\n", v32);
    rudisha 0;
}
