husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"

Tokeni my_tokeni(Msomaji* m) {
    Tokeni t;
    t.aina = 0;
    N8 c = m->chanzo[m->nafasi];
    kama (ni_alfabeti(c)) {
        N64 anza = m->nafasi;
        wakati (msomaji_imeisha(m) == 0) {
            N8 ch2 = m->chanzo[m->nafasi];
            kama (ni_alfabeti_tarakimu(ch2) == 0) { vunja; }
            m->nafasi = m->nafasi + 1;
            m->safu = m->safu + 1;
        }
        t.urefu = m->nafasi - anza;
        t.mwanzo = m->chanzo + anza;
        t.aina = 3;
    }
    rudisha t;
}

N32 main() {
    N8* s = "abc def";
    Msomaji ms = msomaji_mpya(s, 7);
    Tokeni t = my_tokeni(&ms);
    N32 n32 = ms.nafasi;
    N32 u32 = t.urefu;
    andika("; nafasi=%d urefu=%d (expect 3 3)\n", n32, u32);
    rudisha 0;
}
