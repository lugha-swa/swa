husisha C::stdio
husisha "msingi/msambazaji.swa"
husisha "msingi/mteremko.swa"

N32 main(N32 argc, N8** argv) {
    // Build a minimal AST manually and call teremsha
    // Create a program node wrapping an empty function
    N32 name_node = node_mpya(AST_KITAMBULISHO, 0, -1, -1);
    hifadhi_jina(name_node, "jaribu", 6);
    N32 func_node = node_mpya(AST_KAZI, 0, name_node, -1);
    ast_tiga[func_node] = -1;  // no body
    N32 prog_node = node_mpya(AST_PROGRAMU, 0, func_node, -1);

    andika("; Inateremsha...\n");
    teremsha(prog_node);
    andika("; Imeteremshwa.\n");
    rudisha 0;
}
