husisha C::stdio
husisha "msingi/msambazaji.swa"
husisha "msingi/mteremko.swa"

N32 main(N32 argc, N8** argv) {
    // Build minimal AST: PROGRAMU wrapping nothing
    N32 prog = node_mpya(AST_PROGRAMU, 0, -1, -1);

    andika("; Kabla ya teremsha_kichwa...\n");
    teremsha_kichwa();
    andika("; Baada ya kichwa, kabla ya teremsha_aina_walk...\n");
    teremsha_aina_walk(prog);
    andika("; Baada ya teremsha_aina_walk.\n");
    rudisha 0;
}
