husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"

N32 main() {
    N8* s = "N32 f() { rudisha 1; }";
    N64 u = 22;

    Msomaji ms = msomaji_mpya(s, u);
    andika("; ms.chanzo ok\n");

    Tokeni t;
    tokeni_inayofuata(&t, &ms);
    andika("; T: aina=%d urefu=%d mwanzo[0]=%c\n", t.aina, t.urefu, t.mwanzo[0]);

    tokeni_inayofuata(&t, &ms);
    andika("; T: aina=%d urefu=%d mwanzo[0]=%c\n", t.aina, t.urefu, t.mwanzo[0]);

    rudisha 0;
}
