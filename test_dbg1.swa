husisha C::stdio
husisha "msingi/mteremko.swa"

N32 main(N32 argc, N8** argv) {
    andika("; A\n");
    N32 name_node = node_mpya(AST_KITAMBULISHO, 0, -1, -1);
    andika("; B: name_node=%d\n", name_node);
    hifadhi_jina(name_node, "jaribu", 6);
    andika("; C\n");
    N32 func_node = node_mpya(AST_KAZI, 0, name_node, -1);
    andika("; D: func_node=%d\n", func_node);
    N32 prog = node_mpya(AST_PROGRAMU, 0, func_node, -1);
    andika("; E: prog=%d\n", prog);
    teremsha_kichwa();
    andika("; F\n");
    rudisha 0;
}
