// Test file for new expression operators in Swa parser
husisha C::stdio

W0 jaribu_hamisha(N32 x, N32 y) {
    N32 kushoto = x << 2;
    N32 kulia = y >> 1;
    andika("hamisha: %d %d\n", kushoto, kulia);
}

W0 jaribu_bit(N32 x, N32 y) {
    N32 na = x & y;
    N32 au = x | y;
    andika("bit: %d %d\n", na, au);
}

N32 jaribu_ternary(N32 x) {
    rudisha x > 0 ? 1 : 0;
}

N32 main() {
    jaribu_hamisha(4, 8);
    jaribu_bit(6, 3);
    jaribu_ternary(5);
    rudisha 0;
}
