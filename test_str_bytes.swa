N32 main() {
    N8* s = "N32 f() { rudisha 1; }";
    N32 b4 = s[4];
    N32 b5 = s[5];
    N32 b6 = s[6];
    N32 b7 = s[7];
    andika("; s[4]=%d(%c) s[5]=%d(%c) s[6]=%d(%c) s[7]=%d(%c)\n",
        b4, b4, b5, b5, b6, b6, b7, b7);
    rudisha 0;
}
