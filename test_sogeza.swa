husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"
husisha "msingi/msambazaji.swa"

N32 main() {
    N8* s = "N32 f() { rudisha 1; }";
    N64 u = 22;

    Msambazaji p = msambazaji_mpya(s, u);

    N32 a1 = p.sasa.aina;
    N32 c1 = p.sasa.mwanzo[0];
    andika("; sasa: a=%d c=%d (expect 3,78)\n", a1, c1);

    N32 a2 = p.inayofuata.aina;
    N32 c2 = p.inayofuata.mwanzo[0];
    andika("; inayo: a=%d c=%d (expect 3,102)\n", a2, c2);

    sogeza(&p);

    N32 a3 = p.sasa.aina;
    N32 c3 = p.sasa.mwanzo[0];
    andika("; after sogeza sasa: a=%d c=%d (expect 3,102)\n", a3, c3);

    N32 a4 = p.inayofuata.aina;
    N32 c4 = p.inayofuata.mwanzo[0];
    andika("; after sogeza inayo: a=%d c=%d (expect 5,40)\n", a4, c4);

    rudisha 0;
}
