husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"
husisha "msingi/msambazaji.swa"

N32 main() {
    andika("; start\n");
    N8* s = "N32 f() { rudisha 1; }";
    N64 u = 22;
    Msambazaji p = msambazaji_mpya(s, u);
    andika("; calling kazi\n");
    N32 node = changanua_kazi(&p);
    andika("; node=%d kosa=%d\n", node, p.kosa);
    rudisha 0;
}
