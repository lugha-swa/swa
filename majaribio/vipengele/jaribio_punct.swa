husisha { ../../msingi/kumbukumbu.swa }
husisha { ../../msingi/mfuatano.swa }
husisha { ../../msingi/msomaji.swa }

N32 main() {
    N8 c = 40;
    N32 result = 0;
    kama (c == 59 || c == 44 || c == 58 || c == 40 || c == 41 || c == 91 || c == 93 || c == 123 || c == 125) {
        result = 1;
    }
    andika("; punct(40)=%d (expect 1)\n", result);

    c = 41;
    result = 0;
    kama (c == 59 || c == 44 || c == 58 || c == 40 || c == 41 || c == 91 || c == 93 || c == 123 || c == 125) {
        result = 1;
    }
    andika("; punct(41)=%d (expect 1)\n", result);

    c = 102;
    result = 0;
    kama (c == 59 || c == 44 || c == 58 || c == 40 || c == 41 || c == 91 || c == 93 || c == 123 || c == 125) {
        result = 1;
    }
    andika("; punct(102)=%d (expect 0)\n", result);

    rudisha 0;
}
