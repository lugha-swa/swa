husisha C::stdio
husisha { ../../msingi/msomaji.swa }

N8 chanzo_buf[16];
N32 chanzo_urefu = 0;

N32 main(N32 argc, N8** argv) {
    chanzo_buf[0] = 87;  // 'W'
    chanzo_urefu = 1;
    Msomaji m = msomaji_mpya(chanzo_buf, chanzo_urefu);
    Tokeni t = tokeni_inayofuata(&m);
    andika("; aina=%d urefu=%d\n", t.aina, t.urefu);
    rudisha 0;
}
