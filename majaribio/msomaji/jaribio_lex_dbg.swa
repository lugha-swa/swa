husisha { ../../msingi/kumbukumbu.swa }
husisha { ../../msingi/mfuatano.swa }
husisha { ../../msingi/msomaji.swa }

N32 main() {
    N8* s = "N32 f() { rudisha 1; }";
    N64 u = 22;

    Msomaji ms = msomaji_mpya(s, u);
    N32 dbg_n = ms.nafasi;
    andika("; ms.nafasi=%d\n", dbg_n);

    Tokeni t = tokeni_inayofuata(&ms);
    N32 dbg_a = t.aina;
    N32 dbg_c = t.mwanzo[0];
    andika("; T0: a=%d c=%d\n", dbg_a, dbg_c);

    t = tokeni_inayofuata(&ms);
    dbg_a = t.aina;
    dbg_c = t.mwanzo[0];
    andika("; T1: a=%d c=%d\n", dbg_a, dbg_c);

    t = tokeni_inayofuata(&ms);
    dbg_a = t.aina;
    dbg_c = t.mwanzo[0];
    andika("; T2: a=%d c=%d\n", dbg_a, dbg_c);

    t = tokeni_inayofuata(&ms);
    dbg_a = t.aina;
    dbg_c = t.mwanzo[0];
    andika("; T3: a=%d c=%d\n", dbg_a, dbg_c);

    rudisha 0;
}
