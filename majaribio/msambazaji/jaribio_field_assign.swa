husisha { ../../msingi/kumbukumbu.swa }
husisha { ../../msingi/mfuatano.swa }
husisha { ../../msingi/msomaji.swa }

N32 main() {
    Tokeni t;
    t.aina = 0;
    t.urefu = 1;
    t.mstari = 2;
    t.safu = 3;
    N32 a = t.aina;
    N32 u = t.urefu;
    N32 m = t.mstari;
    N32 s = t.safu;
    andika("; a=%d u=%d m=%d s=%d\n", a, u, m, s);
    rudisha 0;
}
