husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"

N32 main() {
    N8* s = "N32 f() { rudisha 1; }";
    N64 u = 22;
    Msomaji ms = msomaji_mpya(s, u);

    // Skip N32 and f using old pattern
    Tokeni t = tokeni_inayofuata(&ms);  // N32
    t = tokeni_inayofuata(&ms);          // f

    // Now at position 5. Check what the lexer sees
    N32 nafasi = ms.nafasi;
    N8 c = ms.chanzo[nafasi];
    andika("; pos=%d c=%d expect pos=5 c=40\n", nafasi, c);

    // Get the third token using the real lexer
    t = tokeni_inayofuata(&ms);
    N32 aina = t.aina;
    N32 ch = t.mwanzo[0];
    andika("; T2 from lexer: a=%d c=%d\n", aina, ch);

    rudisha 0;
}
