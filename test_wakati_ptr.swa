husisha "msingi/kumbukumbu.swa"
husisha "msingi/mfuatano.swa"
husisha "msingi/msomaji.swa"

N32 main() {
    N8* s = "abc def";
    Msomaji ms = msomaji_mpya(s, 7);
    Msomaji* m = &ms;

    N64 count = 0;
    // Read while alphanumeric using POINTER
    wakati (msomaji_imeisha(m) == 0) {
        N8 ch = m->chanzo[m->nafasi];
        kama (ni_alfabeti_tarakimu(ch) == 0) { vunja; }
        m->nafasi = m->nafasi + 1;
        m->safu = m->safu + 1;
        count = count + 1;
    }

    N32 c32 = count;
    N32 n32 = m->nafasi;
    andika("; count=%d nafasi=%d (expect count=3 nafasi=3)\n", c32, n32);
    rudisha 0;
}
