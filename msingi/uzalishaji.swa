// sub rsp, 8; movss [rsp], xmm0  — sukuma D32 kwenye rafu
W0 andika_push_xmm0() { andika_baiti(72); andika_baiti(131); andika_baiti(236); andika_baiti(8); andika_baiti(0); andika_baiti(0); andika_baiti(0); andika_baiti(243); andika_baiti(15); andika_baiti(17); andika_baiti(4); andika_baiti(36); }
// movss xmm1, [rsp]; add rsp, 8 — vuta D32 kutoka rafu
W0 andika_pop_xmm1() { andika_baiti(243); andika_baiti(15); andika_baiti(16); andika_baiti(12); andika_baiti(36); andika_baiti(72); andika_baiti(131); andika_baiti(196); andika_baiti(8); andika_baiti(0); andika_baiti(0); andika_baiti(0); }
