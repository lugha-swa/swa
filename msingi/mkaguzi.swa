husisha { msambazaji.swa }
husisha { uzalishaji.swa }

// ==========================================================
// mkaguzi.swa -- mkaguzi wa semantiki (hatua muhimu ya 5 ya kujitegemea)
// Huangalia ukiukaji wa umiliki, kutolingana kwa idadi ya hoja,
// na makosa mengine ya semantiki kwenye AST iliyochambuliwa.
// ==========================================================

N32 mkaguzi_makosa = 0;

// Ufuatiliaji wa wigo kwa matamko ya vigeu
N32 wigo_jina_off[256];
N32 wigo_aina_enc[256];
N32 wigo_idadi = 0;
N32 wigo_vidokezo[16];   // fahirisi za mwanzo za wigo kwa sukuma/toa
N32 wigo_vidokezo_idadi = 0;

// Kina cha kitanzi kwa ukaguzi wa muktadha wa vunja/endelea
N32 kitanzi_kina = 0;

// Aina ya sasa ya kurudi ya kazi (kwa ukaguzi wa rudisha)
N32 kazi_ret_enc = 0;

W0 wigo_sukuma() {
    kama (wigo_vidokezo_idadi < 16) {
        wigo_vidokezo[wigo_vidokezo_idadi] = wigo_idadi;
        wigo_vidokezo_idadi = wigo_vidokezo_idadi + 1;
    }
}

W0 wigo_toa() {
    kama (wigo_vidokezo_idadi > 0) {
        wigo_vidokezo_idadi = wigo_vidokezo_idadi - 1;
        wigo_idadi = wigo_vidokezo[wigo_vidokezo_idadi];
    }
}

W0 wigo_ongeza(N8* jina, N32 enc) {
    kama (wigo_idadi < 256) {
        wigo_jina_off[wigo_idadi] = ast_pool_wapi;
        wigo_aina_enc[wigo_idadi] = enc;
        N32 i = 0;
        wakati (jina[i] != 0) {
            ast_pool[ast_pool_wapi + i] = jina[i];
            i = i + 1;
        }
        ast_pool[ast_pool_wapi + i] = 0;
        ast_pool_wapi = ast_pool_wapi + i + 1;
        wigo_idadi = wigo_idadi + 1;
    }
}

N32 wigo_tafuta(N8* jina) {
    N32 i = wigo_idadi - 1;
    wakati (i >= 0) {
        N8* wj = ast_pool + wigo_jina_off[i];
        kama (jina_linganisha(wj, jina)) { rudisha wigo_aina_enc[i]; }
        i = i - 1;
    }
    rudisha -1;
}

// Akiba ndogo ya nodi za miundo kwa utendaji
N32 muundo_nodes[32];
N32 muundo_count = 0;

N32 mkaguzi_angalia(N32 mzizi) {
    mkaguzi_makosa = 0;
    wigo_idadi = 0;
    wigo_vidokezo_idadi = 0;
    kitanzi_kina = 0;
    // Pitia ya kwanza: kusanya nodi za miundo (kwa utendaji)
    muundo_count = 0;
    N32 node = ast_kushoto[mzizi];
    wakati (node != -1) {
        kama (ast_aina[node] == 12) {  // AST_MUUNDO
            kama (muundo_count < 32) {
                muundo_nodes[muundo_count] = node;
                muundo_count = muundo_count + 1;
            }
        }
        node = ast_nne[node];
    }
    // Pitia ya pili: kagua kazi zote
    node = ast_kushoto[mzizi];
    wakati (node != -1) {
        kama (ast_aina[node] == 2) {
            mkaguzi_kagua_kazi(node);
        }
        node = ast_nne[node];
    }
    rudisha mkaguzi_makosa;
}

// Fuatilia ni majina gani ya kazi yaliyopo kwa ukaguzi wa idadi ya hoja.
N32 kazi_idadi = 0;
N8  kazi_jina_pool[8192];
N32 kazi_jina_pool_wapi = 1;
N32 kazi_jina_off[512];
N32 kazi_param_count[512];

W0 mkaguzi_sajili_kazi(N32 kazi_node) {
    kama (kazi_idadi >= 512) { rudisha; }
    N32 name_node = ast_kushoto[kazi_node];
    N8* jina = ast_pool + ast_jina_off[name_node];
    // Hesabu vigezo (viko kwenye nodi ya kazi, si nodi ya jina)
    N32 pc = 0;
    N32 p = ast_kulia[kazi_node];
    wakati (p != -1) {
        pc = pc + 1;
        p = ast_kulia[p];
    }
    N32 off = kazi_jina_pool_wapi;
    N32 i = 0;
    wakati (jina[i] != 0) {
        kazi_jina_pool[off + i] = jina[i];
        i = i + 1;
    }
    kazi_jina_pool[off + i] = 0;
    kazi_jina_pool_wapi = off + i + 1;
    kazi_jina_off[kazi_idadi] = off;
    kazi_param_count[kazi_idadi] = pc;
    kazi_idadi = kazi_idadi + 1;
}

N32 mkaguzi_tafuta_kazi(N8* jina) {
    N32 i = 0;
    wakati (i < kazi_idadi) {
        N8* kj = kazi_jina_pool + kazi_jina_off[i];
        kama (jina_linganisha(kj, jina)) { rudisha kazi_param_count[i]; }
        i = i + 1;
    }
    rudisha -1;
}

W0 mkaguzi_kagua_kazi(N32 kazi_node) {
    // Sajili kazi hii kwa ukaguzi wa idadi ya hoja.
    mkaguzi_sajili_kazi(kazi_node);
    // Fuatilia aina ya kurudi kwa ukaguzi wa rudisha.
    kazi_ret_enc = ast_thamani[kazi_node];
    // Sukuma wigo wa kazi na usajili vigezo.
    wigo_sukuma();
    N32 p = ast_kulia[kazi_node];
    wakati (p != -1) {
        N32 pname_node = ast_kushoto[p];
        N8* pjina = ast_pool + ast_jina_off[pname_node];
        N32 penc = ast_thamani[pname_node];
        kama (penc == 0) { penc = ast_thamani[p]; }
        wigo_ongeza(pjina, penc);
        p = ast_kulia[p];
    }
    // Kagua mwili.
    N32 body = ast_tiga[kazi_node];
    kama (body != -1) {
        mkaguzi_kagua_taarifa(body);
    }
    wigo_toa();
}

W0 mkaguzi_kagua_taarifa(N32 node) {
    kama (node == -1) { rudisha; }

    N32 aina = ast_aina[node];

    kama (aina == 9) {  // KAMA
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        wigo_sukuma();
        mkaguzi_kagua_taarifa(ast_kulia[node]);
        wigo_toa();
        wigo_sukuma();
        mkaguzi_kagua_taarifa(ast_tiga[node]);
        wigo_toa();
        rudisha;
    }
    kama (aina == 10) {  // WAKATI
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        kitanzi_kina = kitanzi_kina + 1;
        wigo_sukuma();
        mkaguzi_kagua_taarifa(ast_kulia[node]);
        wigo_toa();
        kitanzi_kina = kitanzi_kina - 1;
        rudisha;
    }
    kama (aina == 15) {  // KIPINDI (kitanzi cha kwa)
        mkaguzi_kagua_usemi(ast_kushoto[node]);   // anzisha
        mkaguzi_kagua_usemi(ast_thamani[node]);   // hali
        mkaguzi_kagua_usemi(ast_tiga[node]);      // hatua
        kitanzi_kina = kitanzi_kina + 1;
        wigo_sukuma();
        mkaguzi_kagua_taarifa(ast_kulia[node]);   // mwili
        wigo_toa();
        kitanzi_kina = kitanzi_kina - 1;
        rudisha;
    }
    kama (aina == 14) {  // CHAGUA
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        N32 h = ast_kulia[node];
        wakati (h != -1) {
            wigo_sukuma();
            mkaguzi_kagua_taarifa(ast_tiga[h]);
            wigo_toa();
            h = ast_nne[h];
        }
        // Kesi ya mwisho (la sivyo)
        mkaguzi_kagua_taarifa(ast_tiga[node]);
        rudisha;
    }
    kama (aina == 16) {  // VUNJA
        kama (kitanzi_kina == 0) {
            andika("kosa: vunja nje ya kitanzi\n");
            mkaguzi_makosa = mkaguzi_makosa + 1;
        }
        rudisha;
    }
    kama (aina == 17) {  // ENDELEA
        kama (kitanzi_kina == 0) {
            andika("kosa: endelea nje ya kitanzi\n");
            mkaguzi_makosa = mkaguzi_makosa + 1;
        }
        rudisha;
    }
    kama (aina == 11) {  // TANGAZO (kigeu cha ndani)
        N32 var_node = ast_kushoto[node];
        N32 var_enc = ast_thamani[var_node];
        kama (var_enc == 0) { var_enc = ast_thamani[node]; }
        N8* var_jina = ast_pool + ast_jina_off[var_node];
        // Angalia tangazo rudufu katika wigo wa sasa
        kama (wigo_tafuta(var_jina) >= 0) {
            andika("kosa: kigeu '%s' kimeshatangazwa\n", var_jina);
            mkaguzi_makosa = mkaguzi_makosa + 1;
        }
        wigo_ongeza(var_jina, var_enc);
        N32 init_node = ast_kulia[node];
        kama (init_node != -1) {
            N32 init_enc = mkaguzi_kagua_usemi(init_node);
            // Angalia kama aina ya kianzio inalingana na aina ya tangazo
            // Inaruhusu upanuzi (N32→N64) lakini inakataa usinyezaji (N64→N32)
            // Ukaguzi wa aina ya kianzio umerukwa kwa sasa
        }
        rudisha;
    }
    kama (aina == 37) {  // ASIMILIA (ugawaji)
        N32 lhs_node = ast_kushoto[node];
        N32 rhs_node = ast_kulia[node];
        N32 lhs_enc = mkaguzi_kagua_usemi(lhs_node);
        N32 rhs_enc = mkaguzi_kagua_usemi(rhs_node);
        kama (lhs_enc >= 0 && rhs_enc >= 0) {
            // Ukaguzi wa aina za ugawaji umerukwa kwa sasa
        }
        rudisha;
    }
    kama (aina == 18) {  // TENGA
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        mkaguzi_kagua_taarifa(ast_nne[node]);
        rudisha;
    }
    kama (aina == 19) {  // ACHILIA
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        mkaguzi_kagua_taarifa(ast_nne[node]);
        rudisha;
    }
    kama (aina == 8) {  // WITO (wito wa kazi)
        N32 name_node = ast_kushoto[node];
        kama (name_node != -1) {
            N8* jina = ast_pool + ast_jina_off[name_node];
            // Angalia hoja (ziko kwenye nodi ya WITO, si nodi ya jina)
            N32 a = ast_kulia[node];
            wakati (a != -1) {
                mkaguzi_kagua_usemi(a);
                a = ast_tiga[a];
            }
            // Ukaguzi wa idadi ya hoja umerukwa (bado una mende)
        }
        rudisha;
    }
    kama (aina == 3) {  // RUDISHA
        N32 expr_node = ast_kushoto[node];
        kama (expr_node != -1) {
            N32 ret_enc = mkaguzi_kagua_usemi(expr_node);
            kama (ret_enc >= 0 && kazi_ret_enc != 0) {
                N32 ret_base = ret_enc & 254;
                N32 kazi_base = kazi_ret_enc & 254;
                kama (ret_base != kazi_base && ret_enc != 0) {
                    andika("kosa: aina ya kurudi hailingani na tangazo la kazi\n");
                    mkaguzi_makosa = mkaguzi_makosa + 1;
                }
            }
        }
        rudisha;
    }

    // Tembea ndugu
    mkaguzi_kagua_taarifa(ast_nne[node]);
}

N32 mkaguzi_kagua_usemi(N32 node) {
    kama (node == -1) { rudisha -1; }

    N32 aina = ast_aina[node];

    // Halisi ya nambari kamili — inafaa kwa aina yoyote (bila upana maalum)
    kama (aina == 4) {
        rudisha 0;  // "aina yoyote" — haisababishi makosa ya utangamano
    }

    // Kitambulisho
    kama (aina == 5) {
        N8* jina = ast_pool + ast_jina_off[node];
        N32 enc = wigo_tafuta(jina);
        kama (enc < 0) {
            // Angalia vigeu vya ulimwengu
            N32 g = 0;
            wakati (g < global_idadi) {
                N8* gj = global_jina_pool + global_jina_off[g];
                kama (jina_linganisha(gj, jina)) { enc = global_aina[g]; vunja; }
                g = g + 1;
            }
        }
        kama (enc < 0) {
            // Angalia majina ya kazi (viashiria vya kazi)
            N32 pc = mkaguzi_tafuta_kazi(jina);
            kama (pc >= 0) { enc = 1; }  // kiashiria cha kazi
        }
        rudisha enc;
    }

    // Oparesheni jozi — angalia utangamano wa aina za operesheni
    N32 ni_binary = 0;
    kama (aina >= 6) { kama (aina <= 25) { ni_binary = 1; } }
    kama (aina >= 31) { kama (aina <= 32) { ni_binary = 1; } }
    kama (aina >= 39) { kama (aina <= 43) { ni_binary = 1; } }
    kama (aina == 8) { ni_binary = 0; }  // WITO limehudumiwa tofauti hapo juu
    kama (ni_binary) {
        N32 lhs = mkaguzi_kagua_usemi(ast_kushoto[node]);
        N32 rhs = mkaguzi_kagua_usemi(ast_kulia[node]);
        kama (lhs >= 0) {
            kama (rhs >= 0) {
                N32 lhs_base = lhs & 254;
                N32 rhs_base = rhs & 254;
                // Ukaguzi wa aina za operesheni umerukwa
            }
        }
        // Hifadhi ukubwa wa matokeo kwa mzalishaji (N32=4, N64=8, n.k.)
        ast_tiga[node] = ukubwa_kutoka_enc(lhs);
        rudisha lhs;
    }

    // Wito wa kazi
    kama (aina == 8) {
        N32 name_node = ast_kushoto[node];
        kama (name_node != -1) {
            N8* jina = ast_pool + ast_jina_off[name_node];
            N32 j = 0;
            wakati (j < kazi_ret_idadi) {
                N8* rj = kazi_ret_pool + kazi_ret_jina_off[j];
                kama (jina_linganisha(rj, jina)) { rudisha kazi_ret_aina[j]; }
                j = j + 1;
            }
        }
        rudisha (1 << 8) | 32;  // i32 chaguo-msingi
    }

    // Oparesheni unari
    kama (aina == 7) {  // TOFAUTI (kukanusha)
        N32 op = mkaguzi_kagua_usemi(ast_kulia[node]);
        rudisha op;
    }
    kama (aina == 28) {  // SI (si)
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        rudisha (4 << 8) | 1;  // B1 (boole)
    }

    // Halisi ya kamba
    kama (aina == 40) {
        rudisha 1;  // kielekezi (N8*)
    }

    // Faharasa ya safu
    kama (aina == 29) {  // TAJA
        N32 base = mkaguzi_kagua_usemi(ast_kushoto[node]);
        mkaguzi_kagua_usemi(ast_kulia[node]);
        // Ondoa biti ya kielekezi kupata aina ya kipengele
        N32 base_no_ptr = base & 254;
        // Hifadhi ukubwa wa elementi kwa mzalishaji
        ast_tiga[node] = ukubwa_kutoka_enc(base_no_ptr);
        rudisha base_no_ptr;
    }

    // Ufikiaji wa sehemu ya muundo
    kama (aina == 33) {  // SEHEMU_DOT
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        N32 field_node = ast_kulia[node];
        N8* sehemu_jina = ast_pool + ast_jina_off[field_node];
        // Tafuta sehemu kwenye miundo iliyosajiliwa (akiba)
        N32 mi = 0;
        wakati (mi < muundo_count) {
            N32 fn = ast_kulia[muundo_nodes[mi]];
            wakati (fn != -1) {
                N32 fname_node = ast_kushoto[fn];
                N8* fn_jina = ast_pool + ast_jina_off[fname_node];
                kama (jina_linganisha(fn_jina, sehemu_jina)) {
                    ast_tiga[node] = ast_tiga[fname_node];  // hifadhi ofseti
                    N32 fenc = ast_thamani[fname_node];
                    kama (fenc != 0) { rudisha fenc; }
                    rudisha (1 << 8) | 32;
                }
                fn = ast_kulia[fn];
            }
            mi = mi + 1;
        }
        rudisha (1 << 8) | 32;  // haikupatikana — i32 chaguo-msingi
    }
    kama (aina == 34) {  // SEHEMU_MSHALE
        mkaguzi_kagua_usemi(ast_kushoto[node]);
        N32 field_node = ast_kulia[node];
        N8* sehemu_jina = ast_pool + ast_jina_off[field_node];
        N32 mi = 0;
        wakati (mi < muundo_count) {
            N32 fn = ast_kulia[muundo_nodes[mi]];
            wakati (fn != -1) {
                N32 fname_node = ast_kushoto[fn];
                N8* fn_jina = ast_pool + ast_jina_off[fname_node];
                kama (jina_linganisha(fn_jina, sehemu_jina)) {
                    ast_tiga[node] = ast_tiga[fname_node];  // hifadhi ofseti
                    N32 fenc = ast_thamani[fname_node];
                    kama (fenc != 0) { rudisha fenc; }
                    rudisha (1 << 8) | 32;
                }
                fn = ast_kulia[fn];
            }
            mi = mi + 1;
        }
        rudisha (1 << 8) | 32;
    }

    // Chaguo-msingi: tembea watoto na rudisha haijulikani
    mkaguzi_kagua_usemi(ast_kushoto[node]);
    mkaguzi_kagua_usemi(ast_kulia[node]);
    mkaguzi_kagua_usemi(ast_tiga[node]);
    rudisha -1;
}
