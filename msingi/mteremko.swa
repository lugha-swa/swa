husisha { msambazaji.swa }

// ==========================================================
// mteremko.swa :: Kipunguza IR cha Swa (hatua muhimu ya 6)
// Hutembea AST iliyotengenezwa na msambazaji.swa na kutoa
// maandishi ya LLVM IR kwa stdout.  Inapakiwa wakati wa utekelezaji na stage1.exe.
// ==========================================================

// -------------------------------------------------------
// Hali ya kiwango cha moduli
// -------------------------------------------------------
N32 vid_hesabu = 0;
N32 blk_hesabu = 0;
N32 blk_sasa = 0;
N32 blk_fungwa = 0;        // 1 kama block ya sasa tayari ina terminator
N32 vid_ni_mshale[8192];   // 1 kama vid N ni aina-ptr, 0 kama ni namba
N32 vid_ni_n64[8192];      // 1 kama vid N ni aina-i64, 0 kama ni i32
N32 vid_aina_arr[8192];    // aina iliyosimbwa ya kila thamani SSA
N32 usemi_upana = 32;      // muktadha wa upana wa namba sasa (32 au 64)

// Jedwali la aina za kurudi za kazi
N32 kazi_ret_idadi = 0;
N8  kazi_ret_pool[8192];
N32 kazi_ret_pool_wapi = 1;
N32 kazi_ret_jina_off[512];
N32 kazi_ret_aina[512];

// Jedwali la vigeu vya ulimwengu
N32 global_idadi = 0;
N8  global_jina_pool[8192];
N32 global_jina_pool_wapi = 1;
N32 global_jina_off[256];
N32 global_aina[256];

// Wigo wa kila kazi
N32 wigo_node[512];
N32 wigo_vid[128];
N32 wigo_aina[128];
N32 wigo_idadi = 0;
N32 wigo_alloca[8192];  // vid alloca iliyotengwa mapema kwa kila nodi AST_TANGAZO
N32 wigo_alloca_idadi = 0;
N32 param_node[16];
N32 param_vid[16];
N32 param_aina[16];
N32 param_idadi = 0;

// Bafa ya hoja za wito
N32 arg_vids[16];

// Rafu ya muktadha wa kitanzi
N32 kitanzi_kina = 0;
N32 kitanzi_header[8];
N32 kitanzi_exit[8];

// Badili/kesi
N32 hali_thamani[16];
N32 hali_blk[16];
N32 hali_idadi = 0;

// Jedwali la herufi halisi
N32 str_idadi = 0;
N8  str_pool[8192];
N32 str_pool_wapi = 1;
N32 str_off[128];

// Ufuatiliaji wa aina za muundo
N32 muundo_idadi_t = 0;
N8  muundo_jina_pool[4096];
N32 muundo_jina_pool_wapi = 1;
N32 muundo_jina_off[32];
N32 muundo_node[32];       // Fahirisi ya nodi AST kwa kila muundo
N32 muundo_enc_val[32];    // Kijiti cha familia-aina kilichosimbwa kwa kila muundo

// Nodi kuu ya programu (imewekwa na teremsha)
N32 mzizi_mkuu = -1;

// vid kwa pointer sret kwa kazi zinazorejesha muundo
N32 sret_vid_sasa = -1;
N32 sret_scratch_vid = -1;   // alloca ya muda iliyotengwa mapema kwa temp za sret

// -------------------------------------------------------
// Msaidizi: tengeneza kitambulisho kipya cha thamani SSA
// -------------------------------------------------------
N32 vid_mpya() {
    N32 v = vid_hesabu;
    vid_hesabu = vid_hesabu + 1;
    rudisha v;
}

// -------------------------------------------------------
// Msaidizi: tengeneza kitambulisho kipya cha block ya msingi
// -------------------------------------------------------
N32 blk_mpya() {
    N32 b = blk_hesabu;
    blk_hesabu = blk_hesabu + 1;
    rudisha b;
}

// -------------------------------------------------------
// Msaidizi: linganisha herufi mbili za null-terminated kwa usawa
// -------------------------------------------------------
N32 jina_linganisha(N8* a, N8* b) {
    wakati (a[0] != 0 && b[0] != 0) {
        kama (a[0] != b[0]) { rudisha 0; }
        a = a + 1;
        b = b + 1;
    }
    rudisha (a[0] == b[0]);
}

// -------------------------------------------------------
// Msaidizi: pata urefu wa herufi za null-terminated
// -------------------------------------------------------
N32 jina_urefu(N8* s) {
    N32 n = 0;
    wakati (s[n] != 0) { n = n + 1; }
    rudisha n;
}

// -------------------------------------------------------
// Msaidizi: nakili herufi za null-terminated kwenye bwawa
// -------------------------------------------------------
W0 jina_hifadhi(N8* pool, N32* wapi, N8* jina) {
    N32 i = 0;
    wakati (jina[i] != 0) {
        pool[*wapi + i] = jina[i];
        i = i + 1;
    }
    pool[*wapi + i] = 0;
    *wapi = *wapi + i + 1;
}

// -------------------------------------------------------
// Msaidizi: chapisha aina iliyosimbwa kwa sintaksia ya LLVM
// Usimbaji: (familia<<8) | (upana & 254) | (mshale ? 1 : 0)
//   familia 1=N  2=A  3=D  4=B  5=W  6=muundo-mtumiaji
//   mshale bit 0 = pointer
// -------------------------------------------------------
W0 chapisha_aina(N32 enc) {
    N32 mshale = enc & 1;
    kama (mshale != 0) {
        andika("ptr");
        rudisha;
    }
    N32 familia = (enc >> 8) & 255;
    N32 upana = enc & 254;

    kama (familia == 1) {
        kama (upana == 8)  { andika("i8"); }
        sivyo kama (upana == 64) { andika("i64"); }
        sivyo { andika("i32"); }
    }
    sivyo kama (familia == 2) {
        kama (upana == 8)  { andika("i8"); }
        sivyo kama (upana == 64) { andika("i64"); }
        sivyo { andika("i32"); }
    }
    sivyo kama (familia == 3) {
        kama (upana == 16) { andika("half"); }
        sivyo kama (upana == 32) { andika("float"); }
        sivyo kama (upana == 64) { andika("double"); }
        sivyo { andika("float"); }
    }
    sivyo kama (familia == 4) {
        kama (upana == 1) { andika("i1"); }
        sivyo { andika("i32"); }
    }
    sivyo kama (familia == 5) {
        andika("void");
    }
    sivyo kama (familia == 6) {
        // Muundo wa mtumiaji -- jaribu kutafuta jina
        N32 i = 0;
        N32 found = 0;
        wakati (i < muundo_idadi_t) {
            kama (muundo_enc_val[i] == enc) {
                N8* jina = muundo_jina_pool + muundo_jina_off[i];
                andika("%%%s", jina);
                found = 1;
                vunja;
            }
            i = i + 1;
        }
        kama (found == 0) {
            andika("ptr");
        }
    }
    sivyo {
        andika("i32");
    }
}

// -------------------------------------------------------
// Msaidizi: tafuta kigeu katika wigo wa ndani na ulimwengu
// Inarejesha vid alloca, au -1 kama haijapatikana
// -------------------------------------------------------
N32 tafuta_wigo(N8* jina) {
    // Tafuta wigo wa ndani (mpangilio wa nyuma kwa kivuli)
    N32 i = wigo_idadi - 1;
    wakati (i >= 0) {
        N32 pnode = wigo_node[i];
        kama (pnode != -1) {
            N8* wjina = ast_pool + ast_jina_off[pnode];
            kama (jina_linganisha(wjina, jina)) {
                rudisha wigo_vid[i];
            }
        }
        i = i - 1;
    }

    // Tafuta vigeu vya ulimwengu
    i = 0;
    wakati (i < global_idadi) {
        N8* gjina = global_jina_pool + global_jina_off[i];
        kama (jina_linganisha(gjina, jina)) {
            rudisha -2; // -2 inamaanisha ulimwengu (si alloca)
        }
        i = i + 1;
    }

    rudisha -1;
}

// -------------------------------------------------------
// Msaidizi: tafuta ufafanuzi wa muundo kwa jina la sehemu
// Inarejesha fahirisi ya muundo, inaweka *field_idx
// -------------------------------------------------------
N32 tafuta_muundo_kwa_sehemu(N8* field_name, N32* field_idx_ptr) {
    N32 s = 0;
    wakati (s < muundo_idadi_t) {
        N32 mnode = muundo_node[s];
        N32 field = ast_kulia[mnode];
        N32 idx = 0;
        wakati (field != -1) {
            N32 fname_node = ast_kushoto[field];
            kama (fname_node != -1) {
                N8* fname = ast_pool + ast_jina_off[fname_node];
                kama (jina_linganisha(fname, field_name)) {
                    *field_idx_ptr = idx;
                    rudisha s;
                }
            }
            idx = idx + 1;
            field = ast_kulia[field];
        }
        s = s + 1;
    }
    *field_idx_ptr = 0;
    rudisha -1;
}

// -------------------------------------------------------
// Msaidizi: pata vid alloca kwa kigeu (haiundii;
// inatafuta tu).  Kwa ulimwengu, inatoa rejeleo @jina.
// -------------------------------------------------------
W0 andika_anwani_ya_wigo(N8* jina) {
    N32 v = tafuta_wigo(jina);
    kama (v >= 0) {
        andika("%%v%d", v);
    }
    kama (v == -2) {
        // Kigeu cha ulimwengu
        andika("@%s", jina);
    }
}

// -------------------------------------------------------
// Kichwa: target triple, matamko ya nje
// -------------------------------------------------------
W0 teremsha_kichwa() {
    andika("; Generated by mteremko.swa\n");
    andika("target triple = \"x86_64-pc-linux-gnu\"\n\n");
    andika("declare i32 @printf(ptr, ...)\n");
    andika("declare ptr @malloc(i64)\n");
    andika("declare ptr @realloc(ptr, i64)\n");
    andika("declare void @free(ptr)\n");
    andika("declare ptr @fopen(ptr, ptr)\n");
    andika("declare i64 @fread(ptr, i64, i64, ptr)\n");
    andika("declare i32 @fclose(ptr)\n");
    andika("declare void @llvm.memcpy.p0.p0.i64(ptr, ptr, i64, i1)\n");
    andika("\n");
}

// -------------------------------------------------------
// Tembea AST kupata ufafanuzi wa muundo na kutoa
// matamko ya aina za LLVM.  Pia husajili miundo kwa
// utafutaji wa baadaye.
// -------------------------------------------------------
W0 teremsha_aina_walk(N32 mzizi) {
    N32 node = ast_kushoto[mzizi];
    wakati (node != -1) {
        kama (ast_aina[node] == 12) {  // AST_MUUNDO
            N32 name_node = ast_kushoto[node];
            N8* jina = ast_pool + ast_jina_off[name_node];

            // Sajili muundo huu kwa utafutaji wa baadaye
            N32 t = muundo_idadi_t;
            kama (t < 32) {
                muundo_node[t] = node;
                N32 off = muundo_jina_pool_wapi;
                jina_hifadhi(muundo_jina_pool, &muundo_jina_pool_wapi, jina);
                muundo_jina_off[t] = off;
                // Simba "thamani ya muundo" ya kipekee kwa kutumia familia=6, upana=0
                muundo_enc_val[t] = (6 << 8) | 0;
                muundo_idadi_t = t + 1;
            }

            andika("%%%s = type { ", jina);
            N32 field = ast_kulia[node];
            N32 first = 1;
            wakati (field != -1) {
                kama (first == 0) { andika(", "); }
                first = 0;
                N32 fname = ast_kushoto[field];
                N32 faina = ast_thamani[fname];
                chapisha_aina(faina);
                field = ast_kulia[field];
            }
            andika(" }\n");
        }
        node = ast_nne[node];
    }
}

// -------------------------------------------------------
// Kupita kabla: tembea AST na kukusanya herufi halisi zote.
// Herufi hutambuliwa kama nodi KITAMBULISHO ambazo
// jina lililohifadhiwa linaanza na '"' (nukuu-mbili, baiti 34).
// -------------------------------------------------------
W0 kukusanya_mistari(N32 node) {
    kama (node == -1) { rudisha; }

    kama (ast_aina[node] == 5) {  // AST_KITAMBULISHO
        N32 off = ast_jina_off[node];
        kama (off > 0) {
            N8* s = ast_pool + off;
            kama (s[0] == 34) {  // inaanza na nukuu-mbili
                // Angalia kama tayari imekusanywa (kwa offset ya bwawa)
                N32 found = 0;
                N32 j = 0;
                wakati (j < str_idadi) {
                    kama (str_off[j] == off) { found = 1; vunja; }
                    j = j + 1;
                }
                kama (found == 0) {
                    str_off[str_idadi] = off;
                    str_idadi = str_idadi + 1;
                }
            }
        }
        rudisha;  // Nodi KITAMBULISHO ni majani; hakuna watoto
    }

    kukusanya_mistari(ast_kushoto[node]);
    kukusanya_mistari(ast_kulia[node]);
    kukusanya_mistari(ast_tiga[node]);
    kukusanya_mistari(ast_nne[node]);
}

// -------------------------------------------------------
// Toa herufi halisi zote zilizokusanywa kama
// vibadilika vya faragha vya LLVM.  Huondoa nukuu-mbili za kuzunguka.
// -------------------------------------------------------
W0 teremsha_mistari() {
    N32 i = 0;
    wakati (i < str_idadi) {
        N32 off = str_off[i];
        N8* raw = ast_pool + off;

        // Ruka nukuu ya kufungua
        N32 start = 1;
        // Tafuta nukuu ya kufunga (raw inajumuisha nukuu)
        N32 end = start;
        wakati (raw[end] != 0 && raw[end] != 34) { end = end + 1; }
        N32 len = end - start;

        andika("@str.%d = private constant [%d x i8] c\"", i, len + 1);

        N32 j = start;
        wakati (j < end) {
            N8 c = raw[j];
            kama (c == 10) { andika("\\0A"); }
            sivyo kama (c == 92) {
                // Mfuatano wa kutoroka: \n, \t, \r, \\, \", \0
                kama (j + 1 < end) {
                    N8 nc = raw[j + 1];
                    kama (nc == 110) { andika("\\0A"); j = j + 1; }       // \n
                    sivyo kama (nc == 116) { andika("\\09"); j = j + 1; }  // \t
                    sivyo kama (nc == 114) { andika("\\0D"); j = j + 1; }  // \r
                    sivyo kama (nc == 92) { andika("\\\\"); j = j + 1; }   // \\
                    sivyo kama (nc == 34) { andika("\\22"); j = j + 1; }    // \"
                    sivyo kama (nc == 48) { andika("\\00"); j = j + 1; }    // \0
                    sivyo { andika("\\\\"); }  // kutoroka haijulikani, weka halisi
                } sivyo {
                    andika("\\\\");
                }
            }
            sivyo kama (c == 34) { andika("\\22"); }
            sivyo {
                andika("%c", c);
            }
            j = j + 1;
        }

        andika("\\00\"\n");
        i = i + 1;
    }
    kama (str_idadi > 0) { andika("\n"); }
}

// -------------------------------------------------------
// Matamko ya mbele kwa kazi za kujirudia kwa pande zote
// -------------------------------------------------------
W0 teremsha_taarifa(N32 node, N32 ret_enc);
N32 teremsha_usemi(N32 node);
N32 ukubwa_muundo(N32 enc);
W0 nakili_muundo(N32 dest_vid, N32 src_vid, N32 ukubwa);

// -------------------------------------------------------
// Msaidizi: hesabu ukubwa wa baiti za aina ya muundo kwa
// kujumlisha upana wa sehemu zake.
// -------------------------------------------------------
N32 ukubwa_muundo(N32 enc) {
    N32 mshale = enc & 1;
    kama (mshale != 0) { rudisha 8; }  // pointer = baiti 8
    N32 familia = (enc >> 8) & 255;
    kama (familia != 6) {
        // Aina ya msingi: upana wa baiti kutoka kwa upana wa biti
        N32 upana = enc & 254;
        kama (upana <= 8)  { rudisha 1; }
        kama (upana <= 16) { rudisha 2; }
        kama (upana <= 32) { rudisha 4; }
        kama (upana <= 64) { rudisha 8; }
        rudisha 16;
    }
    // Tembea ufafanuzi wa muundo na jumlisha ukubwa wa sehemu
    N32 i = 0;
    wakati (i < muundo_idadi_t) {
        kama (muundo_enc_val[i] == enc) {
            N32 total = 0;
            N32 mnode = muundo_node[i];
            N32 field = ast_kulia[mnode];
            wakati (field != -1) {
                N32 fname = ast_kushoto[field];
                total = total + ukubwa_muundo(ast_thamani[fname]);
                field = ast_kulia[field];
            }
            kama (total < 1) { total = 1; }
            rudisha total;
        }
        i = i + 1;
    }
    rudisha 4;  // mbadala
}

// -------------------------------------------------------
// Msaidizi: toa memcpy kunakili thamani ya muundo kutoka
// pointer moja hadi nyingine.  Inapunguza hadi @llvm.memcpy.p0.p0.i64.
// -------------------------------------------------------
W0 nakili_muundo(N32 dest_vid, N32 src_vid, N32 ukubwa) {
    andika("  call void @llvm.memcpy.p0.p0.i64(ptr %%v%d, ptr %%v%d, i64 %d, i1 false)\n",
           dest_vid, src_vid, ukubwa);
}

// -------------------------------------------------------
// Msaidizi: panua thamani ili kuendana na upana mpana wa namba.
// Inarejesha vid asili ikiwa tayari upana lengwa,
// au vid mpya kwa maagizo sext/zext.
// -------------------------------------------------------
N32 panua_aina(N32 vid, N32 upana_lengo) {
    N32 enc = vid_aina_arr[vid];
    kama (enc & 1) { rudisha vid; }  // pointer — ruka
    N32 upana = enc & 254;
    kama (upana >= upana_lengo) { rudisha vid; }
    N32 familia = (enc >> 8) & 255;
    N8* ext_inst = "sext";
    kama (familia == 2) { ext_inst = "zext"; }  // bila ishara
    N32 ext_vid = vid_mpya();
    vid_aina_arr[ext_vid] = (familia << 8) | upana_lengo;
    andika("  %%v%d = %s i%d %%v%d to i%d\n", ext_vid, ext_inst, upana, vid, upana_lengo);
    rudisha ext_vid;
}

// -------------------------------------------------------
// Kupita kabla: kusanya matamko yote ya vigeu vya ndani ili
// alloca zao ziweze kutolewa kwenye block ya kuingia (inazuia
// uishi wa alloca-katika-kitanzi).
// -------------------------------------------------------
W0 kukusanya_vigeu(N32 node) {
    kama (node == -1) { rudisha; }
    kama (ast_aina[node] == 11) {  // AST_TANGAZO
        kama (wigo_alloca_idadi < 8192) {
            wigo_alloca[node] = 1;  // weka alama nodi inahitaji alloca kabla
            wigo_alloca_idadi = wigo_alloca_idadi + 1;
        }
    }
    // Jirudie ndani ya watoto
    kukusanya_vigeu(ast_kushoto[node]);
    kukusanya_vigeu(ast_kulia[node]);
    kukusanya_vigeu(ast_tiga[node]);
    // Fuata mlolongo wa taarifa (ast_nne)
    N32 sasa = ast_nne[node];
    wakati (sasa != -1) {
        kukusanya_vigeu(sasa);
        sasa = ast_nne[sasa];
    }
}

// -------------------------------------------------------
// Toa ufafanuzi wa kazi moja kama LLVM IR
// -------------------------------------------------------
W0 teremsha_kazi(N32 kazi_node) {
    N32 name_node = ast_kushoto[kazi_node];
    N32 ret_enc = ast_thamani[kazi_node];
    N8* jina = ast_pool + ast_jina_off[name_node];

    // Weka upya hali ya kila kazi
    wigo_idadi = 0;
    param_idadi = 0;
    kitanzi_kina = 0;
    hali_idadi = 0;
    blk_sasa = 0;

    // Angalia aina ya kurudi ya muundo (sret)
    N32 ret_familia = (ret_enc >> 8) & 255;
    N32 ni_sret = (ret_familia == 6);

    // Toa sahihi ya kazi
    andika("\ndefine ");
    kama (ni_sret) { andika("void"); }
    sivyo { chapisha_aina(ret_enc); }
    andika(" @%s(", jina);

    // Vigezo
    N32 first = 1;

    // Kwa sret: kigezo cha kwanza ni pointer kwa muundo wa kurudi
    sret_vid_sasa = -1;
    kama (ni_sret) {
        N32 sret = vid_mpya();
        sret_vid_sasa = sret;
        vid_aina_arr[sret] = 1; // kielekezi
        andika("ptr %%%d", sret);
        first = 0;
    }

    // Vigezo — zimehifadhiwa katika ast_kulia[func_node]
    N32 p = ast_kulia[kazi_node];
    wakati (p != -1) {
        kama (first == 0) { andika(", "); }
        first = 0;
        N32 p_enc = ast_thamani[p];
        chapisha_aina(p_enc);
        N32 vid = vid_mpya();
        andika(" %%%d", vid);
        vid_aina_arr[vid] = p_enc;
        param_node[param_idadi] = p;
        param_vid[param_idadi] = vid;
        param_aina[param_idadi] = p_enc;
        param_idadi = param_idadi + 1;
        p = ast_kulia[p];
    }
    andika(") {\n");

    // Block ya kuingia
    N32 entry_blk = blk_mpya();
    blk_sasa = entry_blk;
    blk_fungwa = 0;
    andika("b%d:\n", entry_blk);

    // Alloca + store kwa kila kigezo
    N32 i = 0;
    wakati (i < param_idadi) {
        N32 av = vid_mpya();
        N32 p_enc = param_aina[i];
        vid_aina_arr[av] = p_enc | 1;  // alloca inazalisha pointer
        andika("  %%v%d = alloca ", av);
        chapisha_aina(p_enc);
        andika("\n");
        andika("  store ");
        chapisha_aina(p_enc);
        andika(" %%%d, ptr %%v%d\n", param_vid[i], av);
        // Ongeza kwenye wigo
        N32 pnode = param_node[i];
        wigo_node[wigo_idadi] = pnode;
        wigo_vid[wigo_idadi] = av;
        wigo_aina[wigo_idadi] = p_enc;
        wigo_idadi = wigo_idadi + 1;
        i = i + 1;
    }

    // --- Kupita kabla: kusanya matamko yote ya vigeu vya ndani ---
    // Tembea AST ya mwili kupata kila kigeu cha ndani (AST_TANGAZO).
    // Toa alloca zao kwenye block ya kuingia sasa, ili zisitolewe
    // ndani ya miili ya vitanzi (uishi wa alloca-katika-kitanzi).
    wigo_alloca_idadi = 0;
    N32 j = 0;
    wakati (j < 8192) { wigo_alloca[j] = 0; j = j + 1; }
    N32 body = ast_tiga[kazi_node];
    kama (body != -1) {
        kukusanya_vigeu(body);
    }
    // Toa alloca zilizotengwa mapema kwenye block ya kuingia
    j = 0;
    wakati (j < 8192) {
        kama (wigo_alloca[j] != 0) {
            N32 var_node = j;
            N32 var_enc = ast_thamani[var_node];
            N32 av = vid_mpya();
            vid_aina_arr[av] = var_enc | 1;  // kielekezi
            andika("  %%v%d = alloca ", av);
            chapisha_aina(var_enc);
            andika("\n");
            wigo_alloca[var_node] = av;  // hifadhi vid alloca
        }
        j = j + 1;
    }

    // Tenga bafa ya muda kwa sret temp za kurudi
    kama (ni_sret) {
        sret_scratch_vid = vid_mpya();
        vid_aina_arr[sret_scratch_vid] = 1; // kielekezi
        andika("  %%v%d = alloca ", sret_scratch_vid);
        chapisha_aina(ret_enc);
        andika("\n");
    }

    // Toa mwili
    kama (body != -1) {
        teremsha_taarifa(body, ret_enc);
    }

    // Rudisha kwa siri kwa kazi za void ikiwa hakuna terminator ilitolewa
    kama (blk_fungwa == 0) {
        N32 ret_familia = (ret_enc >> 8) & 255;
        kama (ret_familia == 5) {
            andika("  ret void\n");
        }
    }

    andika("}\n");
}

// -------------------------------------------------------
// Usemi: toa hati-ya-safu / fahirisi-ya-kielekezi GEP+pakia
// node = AST_TAJA(base_expr, index_expr)
// -------------------------------------------------------
N32 teremsha_safu(N32 node) {
    N32 base_node = ast_kushoto[node];
    N32 idx_node = ast_kulia[node];

    // Kwa hati-ya-safu, tunahitaji anwani ya msingi (alloca) si thamani iliyopakiwa
    N32 base_addr_vid = -1;
    kama (ast_aina[base_node] == 5) {  // KITAMBULISHO
        N8* bjina = ast_pool + ast_jina_off[base_node];
        base_addr_vid = tafuta_wigo(bjina);
    }
    kama (base_addr_vid < 0) {
        // Mbadala: tathmini kama usemi (inaweza kuwa alloca kutoka usemi mdogo)
        base_addr_vid = teremsha_usemi(base_node);
    }

    N32 idx_vid = teremsha_usemi(idx_node);

    N32 gep_vid = vid_mpya();
    vid_aina_arr[gep_vid] = 1; // kielekezi
    andika("  %%v%d = getelementptr i32, ptr %%v%d, i32 %%v%d\n",
           gep_vid, base_addr_vid, idx_vid);

    N32 load_vid = vid_mpya();
    vid_aina_arr[load_vid] = (1 << 8) | 32; // i32
    andika("  %%v%d = load i32, ptr %%v%d\n", load_vid, gep_vid);
    rudisha load_vid;
}

// -------------------------------------------------------
// Usemi: ufikiaji wa sehemu ya muundo kwa nukta (msingi.sehemu)
// Msingi lazima utathmini kwa anwani ya kumbukumbu (alloca), si thamani iliyopakiwa.
// -------------------------------------------------------
N32 teremsha_sehemu_dot(N32 base_node, N32 field_node) {
    N8* field_name = ast_pool + ast_jina_off[field_node];

    // Pata *anwani* ya muundo msingi (si thamani iliyopakiwa)
    N32 base_addr_vid = -1;
    kama (ast_aina[base_node] == 5) {  // KITAMBULISHO
        N8* bjina = ast_pool + ast_jina_off[base_node];
        base_addr_vid = tafuta_wigo(bjina);
    }
    sivyo {
        // Usemi tata -- tathmini na tumaini utatoa anwani
        base_addr_vid = teremsha_usemi(base_node);
    }

    // Mbadala ikiwa hatukuweza kupata anwani halali
    kama (base_addr_vid < 0) {
        N32 load_vid = vid_mpya();
        vid_aina_arr[load_vid] = (1 << 8) | 32;
        andika("  %%v%d = add i32 0, 0\n", load_vid);
        rudisha load_vid;
    }

    // Tafuta fahirisi ya muundo na fahirisi ya sehemu
    N32 field_idx = 0;
    N32 mu_idx = tafuta_muundo_kwa_sehemu(field_name, &field_idx);
    kama (mu_idx < 0) {
        // Mbadala: toa kama i8 GEP
        N32 gep_vid = vid_mpya();
        vid_aina_arr[gep_vid] = 1; // kielekezi
        andika("  %%v%d = getelementptr i8, ptr %%v%d, i32 0\n", gep_vid, base_addr_vid);
        N32 load_vid = vid_mpya();
        vid_aina_arr[load_vid] = (1 << 8) | 32; // mbadala i32
        andika("  %%v%d = load i32, ptr %%v%d\n", load_vid, gep_vid);
        rudisha load_vid;
    }

    N8* mu_jina = muundo_jina_pool + muundo_jina_off[mu_idx];

    N32 gep_vid = vid_mpya();
    vid_aina_arr[gep_vid] = 1; // kielekezi
    andika("  %%v%d = getelementptr %%%s, ptr %%v%d, i32 0, i32 %d\n",
           gep_vid, mu_jina, base_addr_vid, field_idx);

    // Amua aina ya sehemu kutoka kwa ufafanuzi wa muundo
    N32 mnode = muundo_node[mu_idx];
    N32 field = ast_kulia[mnode];
    N32 fi = 0;
    N32 fenc = (1 << 8) | 32; // default i32
    wakati (field != -1) {
        kama (fi == field_idx) {
            N32 fname_node = ast_kushoto[field];
            fenc = ast_thamani[fname_node];
            vunja;
        }
        fi = fi + 1;
        field = ast_kulia[field];
    }

    N32 load_vid = vid_mpya();
    vid_aina_arr[load_vid] = fenc & 254;
    andika("  %%v%d = load ", load_vid);
    chapisha_aina(fenc & 254);
    andika(", ptr %%v%d\n", gep_vid);
    rudisha load_vid;
}

// -------------------------------------------------------
// Usemi: ufikiaji wa sehemu ya muundo kwa mshale (msingi->sehemu)
// -------------------------------------------------------
N32 teremsha_sehemu_mshale(N32 base_node, N32 field_node) {
    N8* field_name = ast_pool + ast_jina_off[field_node];

    // Kwa ufikiaji wa mshale, msingi ni kigeu cha kielekezi-kwa-muundo.
    // Pakia thamani ya kielekezi kutoka kwa alloca ya kigeu.
    N32 load_ptr_vid = -1;
    kama (ast_aina[base_node] == 5) {  // KITAMBULISHO
        N8* bjina = ast_pool + ast_jina_off[base_node];
        N32 base_addr = tafuta_wigo(bjina);
        kama (base_addr >= 0) {
            load_ptr_vid = vid_mpya();
            vid_aina_arr[load_ptr_vid] = 1; // kielekezi
            andika("  %%v%d = load ptr, ptr %%v%d\n", load_ptr_vid, base_addr);
        }
    }
    kama (load_ptr_vid < 0) {
        // Mbadala: tathmini msingi kama usemi
        load_ptr_vid = teremsha_usemi(base_node);
    }

    // Tafuta muundo na sehemu
    N32 field_idx = 0;
    N32 mu_idx = tafuta_muundo_kwa_sehemu(field_name, &field_idx);
    kama (mu_idx < 0) {
        // Mbadala
        N32 gep_vid = vid_mpya();
        vid_aina_arr[gep_vid] = 1;
        andika("  %%v%d = getelementptr i8, ptr %%v%d, i32 0\n", gep_vid, load_ptr_vid);
        N32 load_vid = vid_mpya();
        vid_aina_arr[load_vid] = (1 << 8) | 32;
        andika("  %%v%d = load i32, ptr %%v%d\n", load_vid, gep_vid);
        rudisha load_vid;
    }

    N8* mu_jina = muundo_jina_pool + muundo_jina_off[mu_idx];

    N32 gep_vid = vid_mpya();
    vid_aina_arr[gep_vid] = 1; // kielekezi
    andika("  %%v%d = getelementptr %%%s, ptr %%v%d, i32 0, i32 %d\n",
           gep_vid, mu_jina, load_ptr_vid, field_idx);

    // Amua aina ya sehemu
    N32 mnode = muundo_node[mu_idx];
    N32 field = ast_kulia[mnode];
    N32 fi = 0;
    N32 fenc = (1 << 8) | 32;
    wakati (field != -1) {
        kama (fi == field_idx) {
            N32 fname_node = ast_kushoto[field];
            fenc = ast_thamani[fname_node];
            vunja;
        }
        fi = fi + 1;
        field = ast_kulia[field];
    }

    N32 load_vid = vid_mpya();
    vid_aina_arr[load_vid] = fenc & 254;
    andika("  %%v%d = load ", load_vid);
    chapisha_aina(fenc & 254);
    andika(", ptr %%v%d\n", gep_vid);
    rudisha load_vid;
}

// -------------------------------------------------------
// Usemi: utoaji wa wito wa kazi
// -------------------------------------------------------
N32 teremsha_wito(N32 wito_node) {
    N32 callee_node = ast_kushoto[wito_node];
    N8* callee = ast_pool + ast_jina_off[callee_node];

    // Kusanya hoja
    N32 arg_count = 0;
    N32 arg = ast_kulia[wito_node];
    wakati (arg != -1) {
        kama (arg_count < 16) {
            arg_vids[arg_count] = teremsha_usemi(arg);
        }
        arg_count = arg_count + 1;
        arg = ast_kulia[arg];
    }

    // Amua mpokeaji halisi (ramani andika -> printf, nk.)
    N8* actual_callee = callee;

    // Shughulikia ramani maalum za majina yaliyojengwa ndani
    N32 ni_andika = jina_linganisha(callee, "andika");
    kama (ni_andika) { actual_callee = "printf"; }

    N32 ni_tenga = jina_linganisha(callee, "tenga");
    kama (ni_tenga) { actual_callee = "malloc"; }
    N32 ni_achilia = jina_linganisha(callee, "achilia");
    kama (ni_achilia) { actual_callee = "free"; }
    N32 ni_badili = jina_linganisha(callee, "badili");
    kama (ni_badili) { actual_callee = "realloc"; }

    // Amua aina ya kurudi
    N32 ret_enc = 0;
    kama (ni_andika) {
        ret_enc = (1 << 8) | 32; // i32
    } sivyo kama (ni_tenga) {
        ret_enc = 1; // kielekezi (bit mshale imewekwa, zingine sifuri)
    } sivyo kama (ni_achilia) {
        ret_enc = (5 << 8) | 0; // aina void
    } sivyo kama (ni_badili) {
        ret_enc = 1; // kielekezi
    } sivyo {
        // Tafuta aina ya kurudi kutoka kwenye kazi zilizosajiliwa
        N32 j = 0;
        N32 found_ret = 0;
        wakati (j < kazi_ret_idadi) {
            N8* rjina = kazi_ret_pool + kazi_ret_jina_off[j];
            kama (jina_linganisha(rjina, callee)) {
                ret_enc = kazi_ret_aina[j];
                found_ret = 1;
                vunja;
            }
            j = j + 1;
        }
        kama (found_ret == 0) {
            // Chaguo-msingi i32
            ret_enc = (1 << 8) | 32;
        }
    }

    // Angalia kama aina ya kurudi ni muundo (inahitaji sret)
    N32 ret_familia_wito = (ret_enc >> 8) & 255;
    N32 ni_sret_wito = (ret_familia_wito == 6);
    N32 sret_alloca_wito = -1;

    kama (ni_sret_wito) {
        // Unda alloca kwa ajili ya kurudi kwa muundo, pitisha kama hoja ya kwanza
        sret_alloca_wito = vid_mpya();
        vid_aina_arr[sret_alloca_wito] = 1; // kielekezi
        andika("  %%v%d = alloca ", sret_alloca_wito);
        chapisha_aina(ret_enc);
        andika("\n");
    }

    N32 result_vid = vid_mpya();
    kama (ni_sret_wito) {
        vid_aina_arr[result_vid] = 1; // inarejesha kielekezi kwa muundo
    } sivyo {
        vid_aina_arr[result_vid] = ret_enc;
    }

    // Toa wito
    kama (ni_sret_wito) {
        andika("  %%v%d = call void @%s(ptr %%v%d", result_vid, actual_callee, sret_alloca_wito);
    } sivyo {
        andika("  %%v%d = call ", result_vid);
        chapisha_aina(ret_enc);
        andika(" @%s(", actual_callee);
    }

    N32 a = 0;
    wakati (a < arg_count) {
        // Katika hali ya sret, hoja halisi ya kwanza inahitaji koma baada ya kielekezi sret.
        kama (a > 0 || ni_sret_wito == 1) { andika(", "); }
        N32 arg_enc = vid_aina_arr[arg_vids[a]];
        chapisha_aina(arg_enc);
        andika(" %%v%d", arg_vids[a]);
        a = a + 1;
    }
    andika(")\n");

    rudisha result_vid;
}

// -------------------------------------------------------
// Usemi: toa LLVM IR kwa nodi ya usemi wa AST
// Inarejesha kitambulisho cha thamani SSA kinachoshikilia matokeo.
// -------------------------------------------------------
N32 teremsha_usemi(N32 node) {
    kama (node == -1) { rudisha -1; }

    N32 aina = ast_aina[node];

    // Nambari halisi
    kama (aina == 4) {  // AST_NAMBARI
        N32 val = ast_thamani[node];
        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (1 << 8) | 32; // i32
        andika("  %%v%d = add i32 %d, 0\n", vid, val);
        rudisha vid;
    }

    // Kitambulisho (rejeleo la kigeu au herufi halisi)
    kama (aina == 5) {  // AST_KITAMBULISHO
        N8* jina = ast_pool + ast_jina_off[node];

        // Angalia kama hii ni herufi halisi (inaanza na ")
        kama (jina[0] == 34) {
            // Tafuta fahirisi ya herufi
            N32 off = ast_jina_off[node];
            N32 si = 0;
            wakati (si < str_idadi) {
                kama (str_off[si] == off) { vunja; }
                si = si + 1;
            }
            kama (si >= str_idadi) {
                // Herufi haikupatikana kwenye jedwali -- mbadala
                N32 vid = vid_mpya();
                vid_aina_arr[vid] = 1; // kielekezi
                andika("  %%v%d = add ptr null, 0\n", vid);
                rudisha vid;
            }
            // Toa GEP kupata i8* kwa data ya herufi
            N32 gep_vid = vid_mpya();
            vid_aina_arr[gep_vid] = 1; // kielekezi
            andika("  %%v%d = getelementptr [0 x i8], ptr @str.%d, i32 0, i32 0\n",
                   gep_vid, si);
            rudisha gep_vid;
        }

        // Rejeleo la kigeu cha kawaida: tafuta kwenye wigo

        // Maalum iliyojengwa ndani: tupu = kielekezi null
        kama (jina_linganisha(jina, "tupu")) {
            N32 vid = vid_mpya();
            vid_aina_arr[vid] = 1; // kielekezi (null)
            andika("  %%v%d = add ptr null, 0\n", vid);
            rudisha vid;
        }

        // Rejeleo la kigeu cha kawaida: tafuta kwenye wigo
        N32 wigo_vid_v = tafuta_wigo(jina);
        kama (wigo_vid_v == -2) {
            // Kigeu cha ulimwengu: pakia kutoka @jina
            N32 load_vid = vid_mpya();
            vid_aina_arr[load_vid] = (1 << 8) | 32; // dhania i32
            andika("  %%v%d = load i32, ptr @%s\n", load_vid, jina);
            rudisha load_vid;
        }
        kama (wigo_vid_v >= 0) {
            // Kigeu cha ndani: vid alloca -- pakia kutoka kwake
            N32 load_vid = vid_mpya();
            N32 enc = wigo_aina[0]; // chaguo-msingi
            // Tafuta aina halisi
            N32 k = 0;
            wakati (k < wigo_idadi) {
                kama (wigo_vid[k] == wigo_vid_v) {
                    enc = wigo_aina[k];
                    vunja;
                }
                k = k + 1;
            }
            N32 val_enc = enc & 254; // ondoa biti ya kielekezi
            vid_aina_arr[load_vid] = val_enc;
            andika("  %%v%d = load ", load_vid);
            chapisha_aina(val_enc);
            andika(", ptr %%v%d\n", wigo_vid_v);
            rudisha load_vid;
        }

        // Haikupatikana -- toa 0 kama mbadala
        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (1 << 8) | 32;
        andika("  %%v%d = add i32 0, 0\n", vid);
        rudisha vid;
    }

    // Waendeshaji wawili
    kama (aina == 6 || aina == 7 || aina == 31 || aina == 32) {  // + - * /
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        N32 rhs_upana = rhs_enc & 254;
        // Lazimisha kwa upana mpana
        N32 upana = lhs_upana;
        kama (rhs_upana > upana) { upana = rhs_upana; }
        lhs_vid = panua_aina(lhs_vid, upana);
        rhs_vid = panua_aina(rhs_vid, upana);

        N8* inst = "add";
        kama (aina == 7)  { inst = "sub"; }
        kama (aina == 31) { inst = "mul"; }
        kama (aina == 32) { inst = "sdiv"; }

        N32 vid = vid_mpya();
        kama (upana > lhs_upana) {
            // Widen result type
            N32 familia = (lhs_enc >> 8) & 255;
            vid_aina_arr[vid] = (familia << 8) | upana;
        } sivyo {
            vid_aina_arr[vid] = lhs_enc;
        }
        andika("  %%v%d = %s i%d %%v%d, %%v%d\n",
               vid, inst, upana, lhs_vid, rhs_vid);
        rudisha vid;
    }

    // Waendeshaji wa shifti za biti
    kama (aina == 39 || aina == 41) {  // kuhama kushoto  kuhama kulia
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 upana = lhs_enc & 254;
        // Lazimisha RHS kwa upana wa LHS (kiasi cha shifti kinalingana na upana wa shifti)
        rhs_vid = panua_aina(rhs_vid, upana);

        N8* inst = "shl";
        kama (aina == 41) { inst = "ashr"; }  // kuhama kulia

        N32 vid = vid_mpya();
        vid_aina_arr[vid] = lhs_enc;
        andika("  %%v%d = %s i%d %%v%d, %%v%d\n",
               vid, inst, upana, lhs_vid, rhs_vid);
        rudisha vid;
    }

    // Waendeshaji wa ulinganisho
    kama (aina == 20 || aina == 21 || aina == 22 || aina == 23 ||
          aina == 24 || aina == 25) {  // == != < > <= >=
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        N32 rhs_upana = rhs_enc & 254;
        // Lazimisha kwa upana mpana
        N32 upana = lhs_upana;
        kama (rhs_upana > upana) { upana = rhs_upana; }
        lhs_vid = panua_aina(lhs_vid, upana);
        rhs_vid = panua_aina(rhs_vid, upana);

        N8* cond = "eq";
        kama (aina == 20) { cond = "eq"; }
        kama (aina == 21) { cond = "ne"; }
        kama (aina == 22) { cond = "slt"; }
        kama (aina == 23) { cond = "sgt"; }
        kama (aina == 24) { cond = "sle"; }
        kama (aina == 25) { cond = "sge"; }

        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (4 << 8) | 1; // i1
        andika("  %%v%d = icmp %s i%d %%v%d, %%v%d\n",
               vid, cond, upana, lhs_vid, rhs_vid);
        rudisha vid;
    }

    // SI la mantiki (kiambishi awali si)
    kama (aina == 28) {  // AST_SI
        N32 operand_vid = teremsha_usemi(ast_kushoto[node]);
        N32 operand_enc = vid_aina_arr[operand_vid];
        N32 operand_upana = operand_enc & 254;
        kama (operand_upana == 0) { operand_upana = 32; }
        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (4 << 8) | 1; // i1
        andika("  %%v%d = icmp eq i%d %%v%d, 0\n", vid, operand_upana, operand_vid);
        rudisha vid;
    }

    // NA ya biti ( &)
    kama (aina == 43) {  // AST_BIT_NA
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        N32 rhs_upana = rhs_enc & 254;
        N32 upana = lhs_upana;
        kama (rhs_upana > upana) { upana = rhs_upana; }
        lhs_vid = panua_aina(lhs_vid, upana);
        rhs_vid = panua_aina(rhs_vid, upana);

        N32 vid = vid_mpya();
        N32 lhs_familia = (lhs_enc >> 8) & 255;
        vid_aina_arr[vid] = (lhs_familia << 8) | upana;
        andika("  %%v%d = and i%d %%v%d, %%v%d\n",
               vid, upana, lhs_vid, rhs_vid);
        rudisha vid;
    }

    // AU ya biti (|)
    kama (aina == 42) {  // AST_BIT_AU
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        N32 rhs_upana = rhs_enc & 254;
        N32 upana = lhs_upana;
        kama (rhs_upana > upana) { upana = rhs_upana; }
        lhs_vid = panua_aina(lhs_vid, upana);
        rhs_vid = panua_aina(rhs_vid, upana);

        N32 vid = vid_mpya();
        N32 lhs_familia = (lhs_enc >> 8) & 255;
        vid_aina_arr[vid] = (lhs_familia << 8) | upana;
        andika("  %%v%d = or i%d %%v%d, %%v%d\n",
               vid, upana, lhs_vid, rhs_vid);
        rudisha vid;
    }

    // NA la mantiki (&&)
    kama (aina == 26) {  // AST_NA
        // Tathmini ya mzunguko-mfupi: badilisha waendeshaji kuwa i1 na WA NA
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        kama (lhs_upana == 0) { lhs_upana = 32; }
        N32 lhs_bool = vid_mpya();
        vid_aina_arr[lhs_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", lhs_bool, lhs_upana, lhs_vid);

        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 rhs_upana = rhs_enc & 254;
        kama (rhs_upana == 0) { rhs_upana = 32; }
        N32 rhs_bool = vid_mpya();
        vid_aina_arr[rhs_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", rhs_bool, rhs_upana, rhs_vid);

        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (4 << 8) | 1;
        andika("  %%v%d = and i1 %%v%d, %%v%d\n", vid, lhs_bool, rhs_bool);
        rudisha vid;
    }

    // AU la mantiki (||)
    kama (aina == 27) {  // AST_AU
        N32 lhs_vid = teremsha_usemi(ast_kushoto[node]);
        N32 lhs_enc = vid_aina_arr[lhs_vid];
        N32 lhs_upana = lhs_enc & 254;
        kama (lhs_upana == 0) { lhs_upana = 32; }
        N32 lhs_bool = vid_mpya();
        vid_aina_arr[lhs_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", lhs_bool, lhs_upana, lhs_vid);

        N32 rhs_vid = teremsha_usemi(ast_kulia[node]);
        N32 rhs_enc = vid_aina_arr[rhs_vid];
        N32 rhs_upana = rhs_enc & 254;
        kama (rhs_upana == 0) { rhs_upana = 32; }
        N32 rhs_bool = vid_mpya();
        vid_aina_arr[rhs_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", rhs_bool, rhs_upana, rhs_vid);

        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (4 << 8) | 1;
        andika("  %%v%d = or i1 %%v%d, %%v%d\n", vid, lhs_bool, rhs_bool);
        rudisha vid;
    }

    // Wito wa kazi
    kama (aina == 8) {  // AST_WITO
        rudisha teremsha_wito(node);
    }

    // Ufikiaji wa sehemu ya muundo (nukta)
    kama (aina == 33) {  // AST_SEHEMU_DOT
        rudisha teremsha_sehemu_dot(ast_kushoto[node], ast_kulia[node]);
    }

    // Ufikiaji wa sehemu ya muundo kwa kielekezi (mshale)
    kama (aina == 34) {  // AST_SEHEMU_MSHALE
        rudisha teremsha_sehemu_mshale(ast_kushoto[node], ast_kulia[node]);
    }

    // Hati-ya-safu / fahirisi-ya-kielekezi / sizeof
    kama (aina == 29) {  // AST_TAJA
        // Tofautisha: sizeof ina mtoto wa kulia == -1, subscript ina fahirisi halisi
        N32 rhs = ast_kulia[node];
        kama (rhs == -1) {
            // sizeof(usemi) -- rudisha ukubwa kwa baiti (siku zote 4 kwa i32, 8 kwa i64/kielekezi)
            // Operesheni iko katika ast_kushoto[node]; tathmini na tupa, kisha rudisha 4
            N32 operand_node = ast_kushoto[node];
            N32 operand_vid = -1;
            kama (operand_node != -1) {
                // Angalia kama ni jina la aina (KITAMBULISHO bila anzisho)
                kama (ast_aina[operand_node] == 5) {
                    // Ni kitambulisho cha aina -- amua ukubwa kutoka kwa usimbaji
                    N32 tena = ast_thamani[operand_node];
                    N32 upana = tena & 254;
                    kama (upana == 0) { upana = 32; } // chaguo-msingi
                    N32 vid = vid_mpya();
                    vid_aina_arr[vid] = (1 << 8) | 32;
                    N32 byte_size = upana / 8;
                    kama (byte_size < 1) { byte_size = 4; }
                    andika("  %%v%d = add i32 %d, 0\n", vid, byte_size);
                    rudisha vid;
                }
            }
            // Mbadala: rudisha 4 (sizeof i32)
            N32 vid = vid_mpya();
            vid_aina_arr[vid] = (1 << 8) | 32;
            andika("  %%v%d = add i32 4, 0\n", vid);
            rudisha vid;
        }
        // Hati-ya-safu ya kawaida
        rudisha teremsha_safu(node);
    }

    // usemi tenga -- ugawaji wa lundo, huthaminiwa kuwa kielekezi
    kama (aina == 18) {  // AST_TENGA
        N32 size_node = ast_kulia[node];
        kama (size_node != -1) {
            N32 size_vid = teremsha_usemi(size_node);
            N32 ext_vid = vid_mpya();
            vid_aina_arr[ext_vid] = (1 << 8) | 64; // namba 64-bit
            andika("  %%v%d = sext i32 %%v%d to i64\n", ext_vid, size_vid);
            N32 ptr_vid = vid_mpya();
            vid_aina_arr[ptr_vid] = 1; // kielekezi
            andika("  %%v%d = call ptr @malloc(i64 %%v%d)\n", ptr_vid, ext_vid);
            rudisha ptr_vid;
        }
        // tenga without argument
        N32 vid = vid_mpya();
        vid_aina_arr[vid] = 1; // kielekezi
        andika("  %%v%d = call ptr @malloc(i64 1)\n", vid);
        rudisha vid;
    }

    // usemi achilia -- toa kumbukumbu, huthaminiwa kuwa void
    kama (aina == 19) {  // AST_ACHILIA
        N32 ptr_node = ast_kulia[node];
        kama (ptr_node != -1) {
            N32 ptr_vid = teremsha_usemi(ptr_node);
            andika("  call void @free(ptr %%v%d)\n", ptr_vid);
        }
        N32 vid = vid_mpya();
        vid_aina_arr[vid] = (5 << 8) | 0; // aina void
        rudisha vid;
    }

    kama (aina == 38) {  // AST_SAFU
        N32 rhs = ast_kulia[node];
        kama (rhs != -1) {
            // Hati-ya-safu: base[rhs] — tuma kwa teremsha_safu
            rudisha teremsha_safu(node);
        }
        // Orodha ya waanzishaji wa muundo { ... } (rhs == -1)
        N32 last_vid = -1;
        N32 elem = ast_kushoto[node];
        wakati (elem != -1) {
            last_vid = teremsha_usemi(elem);
            elem = ast_kulia[elem];
        }
        kama (last_vid == -1) {
            N32 vid = vid_mpya();
            vid_aina_arr[vid] = (1 << 8) | 32;
            andika("  %%v%d = add i32 0, 0\n", vid);
            rudisha vid;
        }
        rudisha last_vid;
    }

    // Ternari (?:)
    kama (aina == 44) {  // AST_TERNARY
        N32 cond_node = ast_kushoto[node];
        N32 kweli_node = ast_kulia[node];
        N32 sikweli_node = ast_tiga[node];

        N32 cond_vid = teremsha_usemi(cond_node);
        // Badilisha hali kuwa i1
        N32 cond_bool = vid_mpya();
        vid_aina_arr[cond_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i32 %%v%d, 0\n", cond_bool, cond_vid);

        N32 kweli_vid = teremsha_usemi(kweli_node);
        N32 kweli_enc = vid_aina_arr[kweli_vid];
        N32 kweli_upana = kweli_enc & 254;

        N32 sikweli_vid = teremsha_usemi(sikweli_node);
        N32 sikweli_enc = vid_aina_arr[sikweli_vid];
        N32 sikweli_upana = sikweli_enc & 254;

        // Coerce both branches to wider width
        N32 upana = kweli_upana;
        kama (sikweli_upana > upana) { upana = sikweli_upana; }
        kweli_vid = panua_aina(kweli_vid, upana);
        sikweli_vid = panua_aina(sikweli_vid, upana);

        N32 vid = vid_mpya();
        N32 familia = (kweli_enc >> 8) & 255;
        vid_aina_arr[vid] = (familia << 8) | upana;
        andika("  %%v%d = select i1 %%v%d, i%d %%v%d, i%d %%v%d\n",
               vid, cond_bool, upana, kweli_vid, upana, sikweli_vid);
        rudisha vid;
    }

    // Usemi wa ugawaji (=)
    kama (aina == 37) {  // AST_ASIMILIA
        N32 lhs_node = ast_kushoto[node];
        N32 rhs_node = ast_kulia[node];
        N32 rhs_vid = teremsha_usemi(rhs_node);
        N32 rhs_enc = vid_aina_arr[rhs_vid];

        kama (ast_aina[lhs_node] == 5) {  // Kigeu rahisi
            N8* jina = ast_pool + ast_jina_off[lhs_node];
            N32 addr_vid = tafuta_wigo(jina);
            kama (addr_vid >= 0) {
                // Tafuta aina kutoka kwa wigo
                N32 lhs_enc = (1 << 8) | 32;
                N32 k = 0;
                wakati (k < wigo_idadi) {
                    kama (wigo_vid[k] == addr_vid) { lhs_enc = wigo_aina[k]; vunja; }
                    k = k + 1;
                }
                // Angalia aina ya muundo: tumia memcpy badala ya store
                N32 lhs_familia = (lhs_enc >> 8) & 255;
                kama (lhs_familia == 6) {
                    // Ugawaji wa muundo kupitia memcpy
                    N32 rhs_addr = -1;
                    kama (ast_aina[rhs_node] == 5) {
                        N8* rjina = ast_pool + ast_jina_off[rhs_node];
                        rhs_addr = tafuta_wigo(rjina);
                    }
                    kama (rhs_addr >= 0) {
                        nakili_muundo(addr_vid, rhs_addr, ukubwa_muundo(lhs_enc));
                    } sivyo {
                        // Mbadala: tumia store (inaweza isifanye kazi kwa miundo)
                        andika("  store ");
                        chapisha_aina(lhs_enc & 254);
                        andika(" %%v%d, ptr %%v%d\n", rhs_vid, addr_vid);
                    }
                } sivyo {
                    andika("  store ");
                    chapisha_aina(lhs_enc & 254);
                    andika(" %%v%d, ptr %%v%d\n", rhs_vid, addr_vid);
                }
            }
            kama (addr_vid == -2) {
                // Ulimwengu
                andika("  store ");
                chapisha_aina(rhs_enc);
                andika(" %%v%d, ptr @%s\n", rhs_vid, jina);
            }
        }
        sivyo kama (ast_aina[lhs_node] == 33) {  // ugawaji wa sehemu kwa nukta
            // Tathmini LHS kupata anwani ya sehemu GEP
            N32 base_node = ast_kushoto[lhs_node];
            N32 field_node = ast_kulia[lhs_node];
            N8* field_name = ast_pool + ast_jina_off[field_node];
            // Pata anwani ya msingi: tumia tafuta_wigo kwa vigeu rahisi,
            // teremsha_usemi kwa usemi tata (tumaini inatoa anwani)
            N32 base_vid = -1;
            kama (ast_aina[base_node] == 5) {
                N8* bjina = ast_pool + ast_jina_off[base_node];
                base_vid = tafuta_wigo(bjina);
            }
            kama (base_vid < 0) {
                base_vid = teremsha_usemi(base_node);
            }

            N32 field_idx = 0;
            N32 mu_idx = tafuta_muundo_kwa_sehemu(field_name, &field_idx);
            kama (mu_idx >= 0) {
                N8* mu_jina = muundo_jina_pool + muundo_jina_off[mu_idx];
                N32 gep_vid = vid_mpya();
                vid_aina_arr[gep_vid] = 1;
                andika("  %%v%d = getelementptr %%%s, ptr %%v%d, i32 0, i32 %d\n",
                       gep_vid, mu_jina, base_vid, field_idx);
                andika("  store ");
                chapisha_aina(rhs_enc);
                andika(" %%v%d, ptr %%v%d\n", rhs_vid, gep_vid);
            }
        }
        sivyo kama (ast_aina[lhs_node] == 34) {  // ugawaji wa sehemu kwa mshale
            N32 base_node = ast_kushoto[lhs_node];
            N32 field_node = ast_kulia[lhs_node];
            N8* field_name = ast_pool + ast_jina_off[field_node];
            // Pakia thamani ya kielekezi kutoka alloca (pakia moja, si mbili)
            N32 base_ptr_vid = -1;
            kama (ast_aina[base_node] == 5) {
                N8* bjina = ast_pool + ast_jina_off[base_node];
                N32 base_addr = tafuta_wigo(bjina);
                kama (base_addr >= 0) {
                    base_ptr_vid = vid_mpya();
                    vid_aina_arr[base_ptr_vid] = 1; // kielekezi
                    andika("  %%v%d = load ptr, ptr %%v%d\n", base_ptr_vid, base_addr);
                }
            }
            kama (base_ptr_vid < 0) {
                base_ptr_vid = teremsha_usemi(base_node);
            }

            N32 field_idx = 0;
            N32 mu_idx = tafuta_muundo_kwa_sehemu(field_name, &field_idx);
            kama (mu_idx >= 0) {
                N8* mu_jina = muundo_jina_pool + muundo_jina_off[mu_idx];
                N32 gep_vid = vid_mpya();
                vid_aina_arr[gep_vid] = 1;
                andika("  %%v%d = getelementptr %%%s, ptr %%v%d, i32 0, i32 %d\n",
                       gep_vid, mu_jina, base_ptr_vid, field_idx);
                andika("  store ");
                chapisha_aina(rhs_enc);
                andika(" %%v%d, ptr %%v%d\n", rhs_vid, gep_vid);
            }
        }
        sivyo kama (ast_aina[lhs_node] == 29) {  // ugawaji wa hati-ya-safu
            N32 arr_node = ast_kushoto[lhs_node];
            N32 idx_node = ast_kulia[lhs_node];
            // Pata anwani ya msingi wa safu: tumia tafuta_wigo kwa vigeu rahisi
            N32 arr_vid = -1;
            kama (ast_aina[arr_node] == 5) {
                N8* ajina = ast_pool + ast_jina_off[arr_node];
                arr_vid = tafuta_wigo(ajina);
            }
            kama (arr_vid < 0) {
                arr_vid = teremsha_usemi(arr_node);
            }
            N32 idx_vid = teremsha_usemi(idx_node);
            N32 gep_vid = vid_mpya();
            vid_aina_arr[gep_vid] = 1;
            andika("  %%v%d = getelementptr i32, ptr %%v%d, i32 %%v%d\n",
                   gep_vid, arr_vid, idx_vid);
            andika("  store ");
            chapisha_aina(rhs_enc);
            andika(" %%v%d, ptr %%v%d\n", rhs_vid, gep_vid);
        }

        rudisha rhs_vid;
    }

    // Mbadala kwa aina za usemi zisizoshughulikiwa
    N32 vid = vid_mpya();
    vid_aina_arr[vid] = (1 << 8) | 32;
    andika("  %%v%d = add i32 0, 0\n", vid);
    rudisha vid;
}

// -------------------------------------------------------
// Taarifa: toa LLVM IR kwa nodi ya taarifa ya AST
// -------------------------------------------------------
W0 teremsha_taarifa(N32 node, N32 ret_enc) {
    kama (node == -1) { rudisha; }

    N32 aina = ast_aina[node];

    // --------------------------------------------------
    // AST_TANGAZO (11) -- tangazo la kigeu cha ndani
    // --------------------------------------------------
    kama (aina == 11) {
        N32 var_node = ast_kushoto[node];
        N32 init_node = ast_kulia[node];
        N32 var_enc = ast_thamani[var_node];
        N8* var_jina = ast_pool + ast_jina_off[var_node];

        // Tumia alloca iliyotengwa mapema kutoka block ya kuingia.
        // Hii inazuia alloca-katika-kitanzi: hata kama tangazo
        // linatokea ndani ya mwili wa kitanzi, alloca inaishi kwenye
        // kuingia kwa kazi na inatekelezwa mara moja tu.
        N32 av = wigo_alloca[var_node];
        kama (av == 0) {
            // Mbadala: hakuna alloca kabla (haipaswi kutokea baada ya kupita kabla)
            av = vid_mpya();
            vid_aina_arr[av] = var_enc | 1;
            andika("  %%v%d = alloca ", av);
            chapisha_aina(var_enc);
            andika("\n");
        }

        // Add to scope
        kama (wigo_idadi < 128) {
            wigo_node[wigo_idadi] = var_node;
            wigo_vid[wigo_idadi] = av;
            wigo_aina[wigo_idadi] = var_enc;
            wigo_idadi = wigo_idadi + 1;
        }

        // Optional initializer
        kama (init_node != -1) {
            // Check if the variable type is a struct
            N32 var_familia = (var_enc >> 8) & 255;
            kama (var_familia == 6) {
                // Struct init via memcpy
                N32 src_addr = -1;
                kama (ast_aina[init_node] == 5) {
                    N8* ijina = ast_pool + ast_jina_off[init_node];
                    src_addr = tafuta_wigo(ijina);
                }
                kama (src_addr >= 0) {
                    nakili_muundo(av, src_addr, ukubwa_muundo(var_enc));
                } sivyo {
                    N32 init_vid = teremsha_usemi(init_node);
                    andika("  store ");
                    chapisha_aina(var_enc);
                    andika(" %%v%d, ptr %%v%d\n", init_vid, av);
                }
            } sivyo {
                N32 init_vid = teremsha_usemi(init_node);
                andika("  store ");
                chapisha_aina(var_enc);
                andika(" %%v%d, ptr %%v%d\n", init_vid, av);
            }
        } sivyo {
            // No initializer: zero-initialize to prevent undef/poison
            N32 var_familia = (var_enc >> 8) & 255;
            kama (var_familia == 6) {
                // Struct: zero through memcpy of zero-fill not needed here
                // (struct alloca is already zero-initialized in LLVM entry block)
            } sivyo {
                andika("  store ");
                chapisha_aina(var_enc);
                andika(" 0, ptr %%v%d\n", av);
            }
        }
    }

    // --------------------------------------------------
    // AST_RUDISHA (3) -- return statement
    // --------------------------------------------------
    sivyo kama (aina == 3) {
        N32 expr_node = ast_kushoto[node];
        kama (expr_node != -1) {
            kama (sret_vid_sasa != -1) {
                // Struct return via sret pointer
                N32 src_addr = -1;
                kama (ast_aina[expr_node] == 5) {
                    N8* rjina = ast_pool + ast_jina_off[expr_node];
                    src_addr = tafuta_wigo(rjina);
                }
                kama (src_addr >= 0) {
                    nakili_muundo(sret_vid_sasa, src_addr, ukubwa_muundo(ret_enc));
                } sivyo {
                    // Complex expression: evaluate, store to temp scratch, memcpy
                    N32 rv = teremsha_usemi(expr_node);
                    andika("  store ");
                    chapisha_aina(ret_enc);
                    andika(" %%v%d, ptr %%v%d\n", rv, sret_scratch_vid);
                    nakili_muundo(sret_vid_sasa, sret_scratch_vid, ukubwa_muundo(ret_enc));
                }
                andika("  ret void\n");
                blk_fungwa = 1;
            } sivyo {
                N32 ret_vid = teremsha_usemi(expr_node);
                andika("  ret ");
                chapisha_aina(vid_aina_arr[ret_vid]);
                andika(" %%v%d\n", ret_vid);
                blk_fungwa = 1;
            }
        } sivyo {
            andika("  ret void\n");
            blk_fungwa = 1;
        }
    }

    // --------------------------------------------------
    // AST_KAMA (9) -- if / if-else
    // --------------------------------------------------
    sivyo kama (aina == 9) {
        N32 cond_node = ast_kushoto[node];
        N32 then_node = ast_kulia[node];
        N32 sivyo_node = ast_tiga[node];

        N32 cond_vid = teremsha_usemi(cond_node);

        N32 then_blk = blk_mpya();
        N32 else_blk = blk_mpya();
        N32 merge_blk = blk_mpya();

        // Badilisha hali kuwa i1
        N32 cond_bool = vid_mpya();
        vid_aina_arr[cond_bool] = (4 << 8) | 1;
        N32 cond_enc = vid_aina_arr[cond_vid];
        N32 cond_upana = cond_enc & 254;
        kama (cond_upana == 0) { cond_upana = 32; }
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", cond_bool, cond_upana, cond_vid);

        kama (sivyo_node != -1) {
            andika("  br i1 %%v%d, label %%b%d, label %%b%d\n",
                   cond_bool, then_blk, else_blk);
        } sivyo {
            andika("  br i1 %%v%d, label %%b%d, label %%b%d\n",
                   cond_bool, then_blk, merge_blk);
        }
        blk_fungwa = 1;

        // Then block
        blk_sasa = then_blk;
        blk_fungwa = 0;
        andika("b%d:\n", then_blk);
        teremsha_taarifa(then_node, ret_enc);
        kama (blk_fungwa == 0) {
            andika("  br label %%b%d\n", merge_blk);
            blk_fungwa = 1;
        }

        // Else block
        kama (sivyo_node != -1) {
            blk_sasa = else_blk;
            blk_fungwa = 0;
            andika("b%d:\n", else_blk);
            // sivyo_node is AST_SIVYO wrapping the else body
            N32 else_body = ast_kushoto[sivyo_node];
            kama (else_body == -1) { else_body = ast_kulia[sivyo_node]; }
            teremsha_taarifa(else_body, ret_enc);
            kama (blk_fungwa == 0) {
                andika("  br label %%b%d\n", merge_blk);
                blk_fungwa = 1;
            }
        }

        // Merge block
        blk_sasa = merge_blk;
        blk_fungwa = 0;
        andika("b%d:\n", merge_blk);
    }

    // --------------------------------------------------
    // AST_WAKATI (10) -- while loop
    // --------------------------------------------------
    sivyo kama (aina == 10) {
        N32 cond_node = ast_kushoto[node];
        N32 body_node = ast_kulia[node];

        N32 header_blk = blk_mpya();
        N32 body_blk = blk_mpya();
        N32 exit_blk = blk_mpya();

        // Push loop context
        N32 kk = kitanzi_kina;
        kama (kk < 8) {
            kitanzi_header[kk] = header_blk;
            kitanzi_exit[kk] = exit_blk;
            kitanzi_kina = kk + 1;
        }

        andika("  br label %%b%d\n", header_blk);
        blk_fungwa = 1;

        // Header block
        blk_sasa = header_blk;
        blk_fungwa = 0;
        andika("b%d:\n", header_blk);
        N32 cond_vid = teremsha_usemi(cond_node);
        N32 cond_enc = vid_aina_arr[cond_vid];
        N32 cond_upana = cond_enc & 254;
        kama (cond_upana == 0) { cond_upana = 32; }
        N32 cond_bool = vid_mpya();
        vid_aina_arr[cond_bool] = (4 << 8) | 1;
        andika("  %%v%d = icmp ne i%d %%v%d, 0\n", cond_bool, cond_upana, cond_vid);
        andika("  br i1 %%v%d, label %%b%d, label %%b%d\n",
               cond_bool, body_blk, exit_blk);
        blk_fungwa = 1;

        // Body block
        blk_sasa = body_blk;
        blk_fungwa = 0;
        andika("b%d:\n", body_blk);
        teremsha_taarifa(body_node, ret_enc);
        kama (blk_fungwa == 0) {
            andika("  br label %%b%d\n", header_blk);
            blk_fungwa = 1;
        }

        // Exit block
        blk_sasa = exit_blk;
        blk_fungwa = 0;
        andika("b%d:\n", exit_blk);

        // Pop loop context
        kitanzi_kina = kk;
    }

    // --------------------------------------------------
    // AST_VUNJA (16) -- break
    // --------------------------------------------------
    sivyo kama (aina == 16) {
        kama (kitanzi_kina > 0) {
            N32 kk = kitanzi_kina - 1;
            andika("  br label %%b%d\n", kitanzi_exit[kk]);
            blk_fungwa = 1;
        }
    }

    // --------------------------------------------------
    // AST_ENDELEA (17) -- continue
    // --------------------------------------------------
    sivyo kama (aina == 17) {
        kama (kitanzi_kina > 0) {
            N32 kk = kitanzi_kina - 1;
            andika("  br label %%b%d\n", kitanzi_header[kk]);
            blk_fungwa = 1;
        }
    }

    // --------------------------------------------------
    // AST_TENGA (18) -- teng expr  => malloc(size)
    // --------------------------------------------------
    sivyo kama (aina == 18) {
        N32 expr_node = ast_kulia[node];
        kama (expr_node != -1) {
            N32 size_vid = teremsha_usemi(expr_node);
            N32 ext_vid = vid_mpya();
            vid_aina_arr[ext_vid] = (1 << 8) | 64; // namba 64-bit
            andika("  %%v%d = sext i32 %%v%d to i64\n", ext_vid, size_vid);
            N32 ptr_vid = vid_mpya();
            vid_aina_arr[ptr_vid] = 1; // kielekezi
            andika("  %%v%d = call ptr @malloc(i64 %%v%d)\n", ptr_vid, ext_vid);
        }
    }

    // --------------------------------------------------
    // AST_ACHILIA (19) -- achilia expr  => free(ptr)
    // --------------------------------------------------
    sivyo kama (aina == 19) {
        N32 expr_node = ast_kulia[node];
        kama (expr_node != -1) {
            N32 ptr_vid = teremsha_usemi(expr_node);
            andika("  call void @free(ptr %%v%d)\n", ptr_vid);
        }
    }

    // --------------------------------------------------
    // AST_CHAGUA (14) -- switch statement
    // --------------------------------------------------
    sivyo kama (aina == 14) {
        N32 tested_node = ast_kushoto[node];
        N32 hali_list = ast_kulia[node];

        N32 test_vid = teremsha_usemi(tested_node);

        N32 default_blk = blk_mpya();
        N32 merge_blk = blk_mpya();
        N32 exit_blk = blk_mpya();

        // Push loop context for vunja support inside switch
        N32 kk = kitanzi_kina;
        kama (kk < 8) {
            kitanzi_header[kk] = -1; // no continue in switch
            kitanzi_exit[kk] = exit_blk;
            kitanzi_kina = kk + 1;
        }

        // Count cases
        N32 case_count = 0;
        N32 chk = hali_list;
        wakati (chk != -1) {
            case_count = case_count + 1;
            chk = ast_nne[chk];
        }

        // Emit switch
        andika("  switch i32 %%v%d, label %%b%d [\n", test_vid, default_blk);
        blk_fungwa = 1;

        // Build case blocks, emit case targets
        chk = hali_list;
        wakati (chk != -1) {
            N32 label_node = ast_kushoto[chk];
            N32 case_blk = blk_mpya();

            N32 case_val = 0;
            kama (ast_aina[label_node] == 4) {  // AST_NAMBARI
                case_val = ast_thamani[label_node];
            }

            kama (hali_idadi < 16) {
                hali_thamani[hali_idadi] = case_val;
                hali_blk[hali_idadi] = case_blk;
                hali_idadi = hali_idadi + 1;
            }

            andika("    i32 %d, label %%b%d\n", case_val, case_blk);
            chk = ast_nne[chk];
        }
        andika("  ]\n");

        // Default block
        blk_sasa = default_blk;
        blk_fungwa = 0;
        andika("b%d:\n", default_blk);
        andika("  br label %%b%d\n", merge_blk);
        blk_fungwa = 1;

        // Emit each case body
        chk = hali_list;
        N32 ci = 0;
        wakati (chk != -1) {
            blk_sasa = hali_blk[ci];
            blk_fungwa = 0;
            andika("b%d:\n", hali_blk[ci]);
            N32 case_body = ast_kulia[chk];
            kama (case_body != -1) {
                teremsha_taarifa(case_body, ret_enc);
            }
            kama (blk_fungwa == 0) {
                andika("  br label %%b%d\n", merge_blk);
                blk_fungwa = 1;
            }
            chk = ast_nne[chk];
            ci = ci + 1;
        }
        hali_idadi = 0;

        // Exit block (for break statements)
        blk_sasa = exit_blk;
        blk_fungwa = 0;
        andika("b%d:\n", exit_blk);
        andika("  br label %%b%d\n", merge_blk);
        blk_fungwa = 1;

        // Merge block
        blk_sasa = merge_blk;
        blk_fungwa = 0;
        andika("b%d:\n", merge_blk);

        kitanzi_kina = kk;
    }

    // --------------------------------------------------
    // AST_ASIMILIA (37) -- assignment statement
    // (same as expression assignment but result discarded)
    // --------------------------------------------------
    sivyo kama (aina == 37) {
        N32 result_vid = teremsha_usemi(node);
        // result is already stored by teremsha_usemi
    }

    // --------------------------------------------------
    // AST_WITO (8) -- function call as statement
    // --------------------------------------------------
    sivyo kama (aina == 8) {
        N32 result_vid = teremsha_usemi(node);
        // Result discarded
    }

    // --------------------------------------------------
    // Default: expression statement (evaluate, discard)
    // --------------------------------------------------
    sivyo {
        // Any other node type: try to evaluate as expression
        N32 result_vid = teremsha_usemi(node);
    }

    // Process next sibling statement (skip if current block already terminated)
    kama (blk_fungwa == 0) {
        teremsha_taarifa(ast_nne[node], ret_enc);
    }
}

// -------------------------------------------------------
// Top-level entry point: emit complete LLVM IR module
// -------------------------------------------------------
W0 teremsha(N32 mzizi) {
    vid_hesabu = 0;
    blk_hesabu = 0;
    muundo_idadi_t = 0;
    muundo_jina_pool_wapi = 1;
    str_idadi = 0;
    str_pool_wapi = 1;
    global_idadi = 0;
    global_jina_pool_wapi = 1;
    kazi_ret_idadi = 0;
    kazi_ret_pool_wapi = 1;
    mzizi_mkuu = mzizi;

    teremsha_kichwa();
    teremsha_aina_walk(mzizi);

    kukusanya_mistari(mzizi);
    teremsha_mistari();

    // Emit global variables (AST_TANGAZO_ULIMWENGU = 35)
    N32 gnode = ast_kushoto[mzizi];
    wakati (gnode != -1) {
        kama (ast_aina[gnode] == 35) {
            N32 gname_node = ast_kushoto[gnode];
            N8* gvname = ast_pool + ast_jina_off[gname_node];
            N32 gena = ast_thamani[gname_node];
            N32 gval = 0;
            N32 ginit_node = ast_kulia[gnode];
            kama (ginit_node != -1) {
                kama (ast_aina[ginit_node] == 4) { gval = ast_thamani[ginit_node]; }
            }

            // Register global for later lookup
            kama (global_idadi < 64) {
                N32 off = global_jina_pool_wapi;
                jina_hifadhi(global_jina_pool, &global_jina_pool_wapi, gvname);
                global_jina_off[global_idadi] = off;
                global_aina[global_idadi] = gena;
                global_idadi = global_idadi + 1;
            }

            andika("@%s = global ", gvname);
            chapisha_aina(gena);
            andika(" %d\n", gval);
        }
        gnode = ast_nne[gnode];
    }
    kama (global_idadi > 0) { andika("\n"); }

    // Pre-pass: register all function return types so forward calls
    // can resolve the correct return type encoding.
    N32 fpnode = ast_kushoto[mzizi];
    wakati (fpnode != -1) {
        kama (ast_aina[fpnode] == 2) {
            N32 fname_node = ast_kushoto[fpnode];
            N8* fjina = ast_pool + ast_jina_off[fname_node];
            N32 fret_enc = ast_thamani[fpnode];
            N32 fidx = kazi_ret_idadi;
            kama (fidx < 128) {
                N32 foff = kazi_ret_pool_wapi;
                jina_hifadhi(kazi_ret_pool, &kazi_ret_pool_wapi, fjina);
                kazi_ret_jina_off[fidx] = foff;
                kazi_ret_aina[fidx] = fret_enc;
                kazi_ret_idadi = fidx + 1;
            }
        }
        fpnode = ast_nne[fpnode];
    }

    // Emit functions (AST_KAZI = 2)
    N32 fnode = ast_kushoto[mzizi];
    wakati (fnode != -1) {
        kama (ast_aina[fnode] == 2) {
            teremsha_kazi(fnode);
        }
        fnode = ast_nne[fnode];
    }
}
