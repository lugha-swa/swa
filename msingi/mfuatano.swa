husisha "kumbukumbu.swa";

N64 urefu_wa_mfuatano(N8* s) {
    N64 n = 0;
    wakati (s[n] != 0) {
        n = n + 1;
    }
    rudisha n;
}

N32 linganisha_mfuatano(N8* a, N8* b) {
    N64 i = 0;
    wakati (a[i] != 0 && b[i] != 0) {
        kama (a[i] < b[i]) {
            rudisha -1;
        }
        kama (a[i] > b[i]) {
            rudisha 1;
        }
        i = i + 1;
    }
    kama (a[i] == 0 && b[i] == 0) {
        rudisha 0;
    }
    kama (a[i] == 0) {
        rudisha -1;
    }
    rudisha 1;
}

W0 nakili_mfuatano(N8* lengwa, N8* chanzo) {
    N64 i = 0;
    wakati (chanzo[i] != 0) {
        lengwa[i] = chanzo[i];
        i = i + 1;
    }
    lengwa[i] = 0;
}

W0 unganisha_mfuatano(N8* lengwa, N8* a, N8* b) {
    N64 i = 0;
    N64 j = 0;
    wakati (a[j] != 0) {
        lengwa[i] = a[j];
        i = i + 1;
        j = j + 1;
    }
    j = 0;
    wakati (b[j] != 0) {
        lengwa[i] = b[j];
        i = i + 1;
        j = j + 1;
    }
    lengwa[i] = 0;
}

N32 tafuta_herufi(N8* s, N8 c) {
    N32 i = 0;
    wakati (s[i] != 0) {
        kama (s[i] == c) {
            rudisha i;
        }
        i = i + 1;
    }
    rudisha -1;
}
