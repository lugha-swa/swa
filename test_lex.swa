N32 main() {
    // Test tokenization of W0
    N8 src[16];
    nakili(src, "W0 nakili()", 11);
    Msomaji ms = msomaji_mpya(src, 11);
    Tokeni t;
    tokeni_inayofuata(&t, &ms);
    andika("; t.aina=%d urefu=%d mwanzo=%.*s\n", t.aina, (N32)t.urefu, (N32)t.urefu, t.mwanzo);
    tokeni_inayofuata(&t, &ms);
    andika("; t.aina=%d urefu=%d mwanzo=%.*s\n", t.aina, (N32)t.urefu, (N32)t.urefu, t.mwanzo);
    rudisha 0;
}
